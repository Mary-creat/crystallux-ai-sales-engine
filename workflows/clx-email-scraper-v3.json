    {
      "parameters": {
        "jsCode": "// CLX Email Scraper v3 — Read website URL from column (no regex)\n// Mode: runOnceForEachItem — processes one lead per SIB iteration.\n\nconst lead = $input.item.json;\nconst lead_id = lead.id;\nconst website = lead.website || '';\n\nif (!website || website.trim() === '') {\n  return { json: { id: lead_id, website_url: null, has_url: false } };\n}\n\n// Normalize: strip trailing slashes, ensure https\nlet url = website.trim();\nif (!url.startsWith('http')) url = 'https://' + url;\n\n// Build contact page fallback (homepage URL + /contact)\nconst contact_url = url.replace(/\\/$/, '') + '/contact';\n\nconsole.log('[clx-email-scraper] lead=' + lead_id + ' website_url=' + url);\n\nreturn {\n  json: {\n    id: lead_id,\n    website_url: url,\n    contact_url: contact_url,\n    has_url: true,\n    company: lead.company\n  }\n};",
        "mode": "runOnceForEachItem"
      },
