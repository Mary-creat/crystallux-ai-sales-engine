    {
      "parameters": {
        "jsCode": "// CLX Follow Up v2 — Prep Update Follow Up\n// Reads the email-ready payload from the upstream Build Follow Up Email\n// (via $('Build Follow Up Email').first().json) since the Gmail node\n// between us replaces the item with its own send result.\n\nconst built = $('Build Follow Up Email').first().json;\n\nconst body = {\n  p_lead_id: built.id,\n  p_fields: {\n    followup_count: built.new_followup_count,\n    followup_sent_at: built.followup_sent_at,\n    next_followup_scheduled_at: built.next_followup_scheduled_at,\n    lead_status: built.new_lead_status,\n    total_emails_sent: built.total_emails_sent,\n    last_email_sent_at: built.last_email_sent_at\n  }\n};\n\nconsole.log('PREP UPDATE:', JSON.stringify({ lead_id: built.id, status: body.p_fields.lead_status, followup_count: body.p_fields.followup_count }));\n\nreturn { json: { ...built, rpc_body: JSON.stringify(body) } };",
        "mode": "runOnceForEachItem"
      },
