    {
      "parameters": {
        "jsCode": "// GUARD 7: 24-hour cooldown + all safety checks\nconst lead = $input.item.json;\n\nif (!lead.email || lead.email.trim() === '') return [];\nif (lead.do_not_contact === true || lead.unsubscribed === true) return [];\nif ((Number(lead.total_emails_sent) || 0) >= 5) return [];\n\nconst hoursSinceLastEmail = lead.last_email_sent_at ?\n  (Date.now() - new Date(lead.last_email_sent_at).getTime()) / 3600000 : 999;\nif (hoursSinceLastEmail < 24) return [];\n\nconst now = new Date();\nconst currentCount = typeof lead.followup_count === 'number' ? lead.followup_count : 0;\nconst newCount = currentCount + 1;\nconst followupSubject = 'Re: ' + (lead.email_subject || '');\n\nlet nextFollowupDate = null;\nlet newLeadStatus = 'Contacted';\n\nif (newCount === 1) {\n  nextFollowupDate = new Date(now.getTime() + 5 * 24 * 60 * 60 * 1000).toISOString();\n} else if (newCount === 2) {\n  nextFollowupDate = new Date(now.getTime() + 10 * 24 * 60 * 60 * 1000).toISOString();\n} else if (newCount >= 3) {\n  nextFollowupDate = null;\n  newLeadStatus = 'Closed Lost';\n}\n\n// GUARD 5: Unsubscribe footer\nconst unsubFooter = '<br><br><hr style=\"border:none;border-top:1px solid #e0e0e0;margin:24px 0;\"><p style=\"font-size:11px;color:#999999;font-family:Arial,sans-serif;\">To unsubscribe reply STOP or <a href=\"mailto:info@crystallux.org?subject=Unsubscribe\" style=\"color:#999999;\">click here</a>.<br>Sent by Crystallux AI | info@crystallux.org</p>';\n\nconst followupBody = (lead.followup_message || '') + unsubFooter;\n\nreturn {\n  json: {\n    ...lead,\n    new_followup_count: newCount,\n    followup_subject: followupSubject,\n    followup_body_with_footer: followupBody,\n    next_followup_scheduled_at: nextFollowupDate,\n    new_lead_status: newLeadStatus,\n    followup_sent_at: now.toISOString(),\n    total_emails_sent: (Number(lead.total_emails_sent) || 0) + 1,\n    last_email_sent_at: now.toISOString(),\n    updated_at: now.toISOString()\n  }\n};",
        "mode": "runOnceForEachItem"
      },
