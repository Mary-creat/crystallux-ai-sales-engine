              "value": "return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ lead_id: $('Parse Twilio Response').first().json.id, node_name: 'twilio_send_failed', error_code: 'WHATSAPP_SEND_FAILED', error_message: ($('Parse Twilio Response').first().json.twilio_error || 'unknown').toString().slice(0, 500), created_at: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "clx-wa-0018",
      "name": "Log Send Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3800,
