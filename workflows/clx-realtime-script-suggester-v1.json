{
  "name": "CLX - Realtime Script Suggester v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "script/suggest",
        "options": { "responseData": "={{ JSON.stringify({ ok: $('Build Response').first().json.ok, suggestions: $('Build Response').first().json.suggestions || [], error: $('Build Response').first().json.error || null }) }}" }
      },
      "id": "clx-rss-v1-0001",
      "name": "Suggester Webhook (DEACTIVATED)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "webhookId": "clx-rss-v1-0001-webhook",
      "notes": "DEACTIVATED. POST /webhook/script/suggest body: { chunk_id, call_id, agent_id, intent (trigger_state), sentiment }. Called from clx-transcript-classifier-realtime-v1 only when intent ∈ {objection, closing_signal, stall, confusion}."
    },
    {
      "parameters": {
        "jsCode": "const body = ($input.item.json && $input.item.json.body) || $input.item.json || {};\nconst chunk_id = body.chunk_id || null;\nconst call_id = body.call_id || null;\nconst agent_id = body.agent_id || null;\nconst intent = body.intent || null;\nconst sentiment = body.sentiment || null;\nif (!chunk_id || !call_id || !intent) return { json: { _error: true, error: 'chunk_id + call_id + intent required', ok: false } };\nreturn { json: { chunk_id, call_id, agent_id, intent, sentiment } };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-rss-v1-0002",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/call_transcript_chunks?id=eq.{{ $json.chunk_id }}&select=client_id,lead_id,clients(id,vertical,niche_name,realtime_script_suggestions_enabled),leads(id,vertical,niche,industry)&limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "clx-rss-v1-0003",
      "name": "Fetch Chunk Context",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 400],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": { "httpHeaderAuth": { "name": "Supabase Crystallux" } }
    },
    {
      "parameters": {
        "jsCode": "const arr = $input.item.json || [];\nconst row = Array.isArray(arr) && arr.length > 0 ? arr[0] : null;\nconst parsed = $('Parse Input').first().json;\nif (!row) return { json: { _skip: true, reason: 'chunk not found', ok: false } };\nconst client = row.clients || {};\nif (!client.realtime_script_suggestions_enabled) return { json: { _skip: true, reason: 'realtime_script_suggestions_enabled=false', ok: false } };\nconst lead = row.leads || {};\nconst vertical = client.niche_name || client.vertical || lead.niche || lead.vertical || lead.industry || null;\nreturn { json: Object.assign({}, parsed, { client_id: row.client_id, lead_id: row.lead_id, vertical }) };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-rss-v1-0004",
      "name": "Resolve Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "clx-rss-if-skip", "leftValue": "={{ $json._skip || false }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "clx-rss-v1-0005",
      "name": "IF Skip",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1160, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/match_script_to_state",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "params=single-object" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ p_trigger_state: $json.intent, p_vertical: $json.vertical, p_lead_context: {}, p_limit: 3 }) }}",
        "options": {}
      },
      "id": "clx-rss-v1-0006",
      "name": "Match Scripts (RPC)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 480],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": { "httpHeaderAuth": { "name": "Supabase Crystallux" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($input.item.json) ? $input.item.json : [];\nconst ctx = $('Resolve Context').first().json;\nif (rows.length === 0) return { json: Object.assign({}, ctx, { _no_match: true, suggestions: [] }) };\nconst suggestions = rows.map(function(r) { return {\n  script_id: r.script_id,\n  script_type: r.script_type,\n  script_title: r.script_title,\n  script_body: r.script_body,\n  rank: r.rank,\n  conversion_rate: r.conversion_rate\n}; });\nreturn { json: Object.assign({}, ctx, { suggestions, _no_match: false }) };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-rss-v1-0007",
      "name": "Shape Suggestions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1640, 480]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "clx-rss-if-nomatch", "leftValue": "={{ $json._no_match === true }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "clx-rss-v1-0008",
      "name": "IF No Match",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1880, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/scan_errors",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ node_name: 'realtime_script_suggester', error_code: 'SCRIPT_MATCH_NO_RESULT', error_message: 'no script matched trigger=' + $json.intent + ' vertical=' + ($json.vertical || 'null'), severity: 'info', created_at: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "clx-rss-v1-0009",
      "name": "Log No Match",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2120, 400],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": { "httpHeaderAuth": { "name": "Supabase Crystallux" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/log_suggestion_shown",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "params=single-object" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ p_call_id: $json.call_id, p_chunk_id: $json.chunk_id, p_agent_id: $json.agent_id, p_client_id: $json.client_id, p_trigger_state: $json.intent, p_trigger_sent: $json.sentiment, p_script_id: $json.suggestions[0].script_id, p_script_type: $json.suggestions[0].script_type, p_content: $json.suggestions[0].script_body, p_rank: $json.suggestions[0].rank }) }}",
        "options": {}
      },
      "id": "clx-rss-v1-0010",
      "name": "Log Suggestion Shown",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2120, 560],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": { "httpHeaderAuth": { "name": "Supabase Crystallux" } },
      "notes": "Logs only the top suggestion at first — the remaining are shown in the dashboard's 'Different one' carousel and only logged when the agent actually sees them."
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Shape Suggestions').first().json || {};\nif (ctx._no_match) return { json: { ok: true, suggestions: [] } };\nreturn { json: { ok: true, suggestions: ctx.suggestions || [] } };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-rss-v1-0011",
      "name": "Build Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2360, 480]
    }
  ],
  "connections": {
    "Suggester Webhook (DEACTIVATED)": { "main": [[ { "node": "Parse Input", "type": "main", "index": 0 } ]] },
    "Parse Input":                     { "main": [[ { "node": "Fetch Chunk Context", "type": "main", "index": 0 } ]] },
    "Fetch Chunk Context":             { "main": [[ { "node": "Resolve Context", "type": "main", "index": 0 } ]] },
    "Resolve Context":                 { "main": [[ { "node": "IF Skip", "type": "main", "index": 0 } ]] },
    "IF Skip":                         { "main": [[ { "node": "Build Response", "type": "main", "index": 0 } ], [ { "node": "Match Scripts (RPC)", "type": "main", "index": 0 } ]] },
    "Match Scripts (RPC)":             { "main": [[ { "node": "Shape Suggestions", "type": "main", "index": 0 } ]] },
    "Shape Suggestions":               { "main": [[ { "node": "IF No Match", "type": "main", "index": 0 } ]] },
    "IF No Match":                     { "main": [[ { "node": "Log No Match", "type": "main", "index": 0 } ], [ { "node": "Log Suggestion Shown", "type": "main", "index": 0 } ]] },
    "Log No Match":                    { "main": [[ { "node": "Build Response", "type": "main", "index": 0 } ]] },
    "Log Suggestion Shown":            { "main": [[ { "node": "Build Response", "type": "main", "index": 0 } ]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "versionId": "clx-realtime-script-suggester-v1",
  "meta": { "templateCredsSetupCompleted": false },
  "id": "clx-realtime-script-suggester-v1",
  "tags": []
}
