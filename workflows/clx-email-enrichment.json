    {
      "parameters": {
        "jsCode": "// CLX Email Enrichment \u2014 Extract Domain from Website URL in notes field\n// Notes format: 'Places ID: ChIJ... | Address: 123 Main St, Toronto, ON | Website: https://example.com'\n\nconst lead = $('Split In Batches').item.json;\nconst notes = lead.notes || '';\n\nconsole.log('Notes:', notes);\n\nlet domain = '';\ntry {\n  const websiteMatch = notes.match(/Website:\\s*(https?:\\/\\/\\S+)/i);\n  if (websiteMatch && websiteMatch[1]) {\n    const cleanUrl = websiteMatch[1]\n      .replace(/[|\\s].*$/, '')\n      .trim();\n    const urlObj = new URL(cleanUrl);\n    domain = urlObj.hostname.replace(/^www\\./, '');\n  }\n} catch(e) {\n  domain = '';\n}\n\nconsole.log('Domain found:', domain);\n\nreturn {\n  json: {\n    ...lead,\n    extracted_domain: domain\n  }\n};"
      },
      "id": "clx13-0000-0000-0000-000000000006",
      "name": "Extract Domain",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ]
    },
