    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://api.hunter.io/v2/domain-search?domain=' + $json.extracted_domain + '&api_key=4778d8309cf86196885d4a07b0f177af19375249&limit=5&type=personal' }}",
        "authentication": "noAuth",
        "options": {}
      },
      "id": "clx13-0000-0000-0000-000000000008",
      "name": "Search Hunter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1880,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// CLX Email Enrichment \u2014 Parse Hunter.io Response\n// Extracts the best email from Hunter.io domain search results\n// Priority: first verified email, then first email found\n\nconst response = $('Search Hunter').item.json;\nconst lead = $('Extract Domain').item.json;\n\nlet bestEmail = '';\n\ntry {\n  const data = response.data || {};\n  const emails = data.emails || [];\n\n  if (emails.length > 0) {\n    // Priority 1: first verified email\n    const verified = emails.find(e => e.verification && e.verification.status === 'valid');\n    if (verified) {\n      bestEmail = verified.value;\n    } else {\n      // Priority 2: first email found\n      bestEmail = emails[0].value || '';\n    }\n  }\n} catch (e) {\n  bestEmail = '';\n}\n\nreturn {\n  json: {\n    id: lead.id,\n    company: lead.company,\n    domain: lead.domain,\n    email: bestEmail\n  }\n};"
      },
      "id": "clx13-0000-0000-0000-000000000009",
