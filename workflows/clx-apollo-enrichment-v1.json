        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/get_monthly_apollo_credits_used",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ p_client_id: $json.client_id || null }) }}",
        "options": {}
      },
      "id": "clx-ap-0006",
      "name": "Check Monthly Credits",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1160,
        400
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": {
        "httpHeaderAuth": {
          "name": "Supabase Crystallux"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Quota gate\n// RPC returns an integer. Basic plan cap ~1,200/month; we guard at\n// 1,150 to keep a buffer for in-flight retries.\n\nconst lead = $('Normalize Lead').first().json;\nconst used = Number($input.item.json) || 0;\nconst CAP = 1150;\n\nif (used > CAP) {\n  return {\n    json: {\n      _skip: true,\n      skip_reason: 'apollo_quota_exceeded',\n      credits_used: used,\n      cap: CAP,\n      lead_id: lead.id,\n      client_id: lead.client_id || null\n    }\n  };\n}\n\nreturn {\n  json: {\n    ...lead,\n    credits_used: used,\n    cap: CAP\n  }\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-ap-0007",
      "name": "Quota Gate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
