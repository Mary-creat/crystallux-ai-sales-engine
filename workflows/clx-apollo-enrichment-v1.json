    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.apollo.io/v1/organizations/enrich",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
