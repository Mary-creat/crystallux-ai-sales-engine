      "name": "Apollo Organization Enrichment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2840,
        500
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "notes": "TODO: Configure APOLLO_API_KEY in .env and create Apollo HTTP Header Auth credential in n8n before activating. Returns employee count, revenue band, tech stack."
    },
    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Prep Update Lead\n// Merges People + Contact + Org enrichment into the leads table.\n// email_source flips to 'apollo_verified' when Apollo returns an email,\n// so downstream scoring and sender selection can grade source quality.\n\nconst lead = $('Normalize Lead').first().json;\nconst pick = $('Pick Primary Contact').first().json;\nconst contact = $('Apollo Contact Enrichment').first().json || {};\nconst org = $('Apollo Organization Enrichment').first().json || {};\n\nconst person = contact.person || contact || {};\nconst organization = (org && org.organization) || {};\n\nconst verifiedEmail = person.email || person.personal_emails?.[0] || null;\nconst directPhone  = person.phone_numbers?.find(p => p.type === 'work_direct')?.sanitized_number\n                  || person.phone_numbers?.[0]?.sanitized_number\n                  || null;\nconst mobilePhone  = person.phone_numbers?.find(p => p.type === 'mobile')?.sanitized_number || null;\n\nconst now = new Date().toISOString();\n\nconst body = {\n  p_lead_id: lead.id,\n  p_fields: {\n    apollo_person_id:    pick.apollo_person_id || person.id || null,\n    apollo_org_id:       pick.apollo_org_id || organization.id || null,\n    verified_email:      verifiedEmail,\n    full_name_verified:  pick.full_name_verified || person.name || null,\n    job_title_verified:  pick.job_title_verified || person.title || null,\n    linkedin_url:        pick.linkedin_url || person.linkedin_url || null,\n    direct_phone:        directPhone,\n    mobile_phone:        mobilePhone,\n    company_size:        organization.estimated_num_employees || null,\n    company_revenue:     organization.annual_revenue_printed || organization.annual_revenue || null,\n    tech_stack:          organization.technology_names || organization.current_technologies || [],\n    industry_verified:   organization.industry || null,\n    location_verified:   [organization.city, organization.state, organization.country].filter(Boolean).join(', ') || null,\n    apollo_enriched_at:  now,\n    email_source:        verifiedEmail ? 'apollo_verified' : (lead.email ? 'scraped' : null)\n  }\n};\n\nreturn { json: { ...lead, rpc_body: JSON.stringify(body) } };",
        "mode": "runOnceForEachItem"
      },
