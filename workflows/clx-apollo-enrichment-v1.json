    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Pick primary contact\n// Chooses the first person whose title matches any of the niche's\n// decision-maker keywords. Falls back to the first person if no\n// match (so the workflow still enriches something useful).\n\nconst searchResp = $('Apollo People Search').first().json;\nconst overlayRows = $input.item.json;\nconst overlay = Array.isArray(overlayRows) ? overlayRows[0] : overlayRows;\n\nconst keywords = (overlay && overlay.apollo_title_keywords) || [];\nconst kwLower = keywords.map(k => String(k).toLowerCase());\n\nconst people = (searchResp && searchResp.people) || [];\n\nlet pick = null;\nfor (const p of people) {\n  const title = String(p.title || '').toLowerCase();\n  if (kwLower.some(k => title.includes(k))) {\n    pick = p;\n    break;\n  }\n}\nif (!pick && people.length > 0) pick = people[0];\n\nif (!pick) {\n  return { json: { _skip: true, skip_reason: 'no_apollo_people_returned' } };\n}\n\nreturn {\n  json: {\n    apollo_person_id: pick.id || null,\n    apollo_org_id: (pick.organization && pick.organization.id) || null,\n    full_name_verified: pick.name || null,\n    job_title_verified: pick.title || null,\n    linkedin_url: pick.linkedin_url || null\n  }\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-ap-0012",
      "name": "Pick Primary Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2360,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.apollo.io/v1/people/match",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
