    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Resolve lead_id\n// Accepts input from either the Schedule Trigger (batch mode — pulled\n// from Supabase below) or the Manual Webhook ({ body: { lead_id } }).\n\nconst input = $input.item.json;\nconst leadId = (input.body && input.body.lead_id) || input.lead_id || null;\n\nreturn {\n  json: {\n    lead_id: leadId,\n    mode: leadId ? 'single' : 'batch'\n  }\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-ap-0003",
      "name": "Resolve Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/leads?id=eq.{{ $json.lead_id }}&select=id,client_id,full_name,company,industry,job_title,city,email,website,apollo_person_id,apollo_enriched_at&limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": false,
        "options": {}
      },
      "id": "clx-ap-0004",
      "name": "Fetch Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        680,
        400
      ],
      "continueOnFail": true,
      "onError": "continueRegularOutput",
      "credentials": {
        "httpHeaderAuth": {
          "name": "Supabase Crystallux"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Normalize Fetch result (array -> object)\nconst rows = $input.item.json;\nconst lead = Array.isArray(rows) ? rows[0] : rows;\nif (!lead || !lead.id) {\n  return { json: { _skip: true, skip_reason: 'lead_not_found' } };\n}\nreturn { json: lead };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-ap-0005",
