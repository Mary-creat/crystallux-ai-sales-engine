    {
      "parameters": {
        "jsCode": "// CLX Apollo Enrichment v1 — Check RPC result and log errors to scan_errors\n\nconst response = $('RPC Update Lead').first().json;\nconst lead = $('Normalize Lead').first().json;\n\nconst responseStr = JSON.stringify(response);\nconst isError = !!(response && (response.error || response.message || (response.code && response.code !== '200')));\n\nif (isError) {\n  return {\n    json: {\n      rpc_error: true,\n      error_body: JSON.stringify({\n        lead_id: lead.id,\n        node_name: 'apollo_enrichment_write_failed',\n        error_code: 'APOLLO_ENRICHMENT_FAILED',\n        error_message: responseStr.substring(0, 500),\n        created_at: new Date().toISOString()\n      })\n    }\n  };\n}\n\nreturn { json: { rpc_error: false, lead_id: lead.id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "clx-ap-0018",
      "name": "Check RPC Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3800,
        500
      ]
    },
    {
