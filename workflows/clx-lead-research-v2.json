      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-haiku-4-5-20251001\", max_tokens: 1024, messages: [{ role: \"user\", content: \"You are a B2B sales intelligence analyst for the Crystallux Sales Engine.\\n\\nAnalyze this lead and return ONLY a raw JSON object. No markdown, no code blocks, no explanation.\\n\\nLead Details:\\nCompany: \" + $json.company + \"\\nIndustry: \" + $json.industry + \"\\nJob Title: \" + $json.job_title + \"\\nCity: \" + $json.city + \"\\nProduct Type: \" + $json.product_type + \"\\n\\nReturn a JSON object with exactly these three string fields:\\n- research_summary: 2-3 sentences about this company and their market position\\n- likely_business_need: the single most likely business challenge this company faces\\n- research_angle: the specific outreach angle to use when contacting this lead\" }] }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-e5f6-4a7b-8c9d-clx000000005",
      "name": "Claude Research Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1160,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "name": "Claude Anthropic"
        }
      },
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// CLX Lead Research v2 — Parse Claude Response\n// Reads Claude API response via $input.item.json and the current lead\n// via $('Split In Batches').first().json (stable first-item accessor).\n\nconst response = $input.item.json;\nconst lead = $('Split In Batches').first().json;\n\nconst rawText = (response && response.content && response.content[0] && response.content[0].text) || '';\n\nlet research;\ntry {\n  const cleaned = rawText.replace(/```json/gi, '').replace(/```/g, '').trim();\n  research = JSON.parse(cleaned);\n} catch (e) {\n  research = {\n    research_summary: rawText.substring(0, 500),\n    likely_business_need: 'Manual review needed',\n    research_angle: 'General outreach'\n  };\n}\n\nconst now = new Date().toISOString();\n\nreturn {\n  json: {\n    id: lead.id,\n    research_summary: research.research_summary || '',\n    likely_business_need: research.likely_business_need || '',\n    research_angle: research.research_angle || '',\n    lead_status: 'Researched',\n    researched_at: now,\n    updated_at: now\n  }\n};",
        "mode": "runOnceForEachItem"
      },
      "id": "a1b2c3d4-e5f6-4a7b-8c9d-clx000000006",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ]
    },
    {
      "parameters": {},
      "id": "a1b2c3d4-e5f6-4a7b-8c9d-clx000000008",
