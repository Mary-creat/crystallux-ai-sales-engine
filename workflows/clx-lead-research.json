              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ research_summary: $json.research_summary, likely_business_need: $json.likely_business_need, research_angle: $json.research_angle, lead_status: $json.lead_status, researched_at: $json.researched_at, updated_at: $json.updated_at }) }}",
        "options": {}
      },
