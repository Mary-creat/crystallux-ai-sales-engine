      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [920, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-sonnet-4-6\", max_tokens: 512, messages: [{ role: \"user\", content: \"You are a B2B lead scoring analyst for the Crystallux AI Sales Engine.\\n\\nScore this lead based on the information provided.\\n\\nCompany: \" + $json.company + \"\\nIndustry: \" + $json.industry + \"\\nJob Title: \" + $json.job_title + \"\\nCity: \" + $json.city + \"\\nProduct Type: \" + $json.product_type + \"\\nResearch Summary: \" + $json.research_summary + \"\\nLikely Business Need: \" + $json.likely_business_need + \"\\nResearch Angle: \" + $json.research_angle + \"\\n\\nScoring criteria:\\n- Industry relevance to AI automation and sales systems (0-25 points)\\n- Job title seniority and decision making authority (0-25 points)\\n- Company size and revenue potential signals (0-25 points)\\n- Urgency and business need strength (0-25 points)\\n\\nReturn ONLY this exact JSON structure with no explanation, no markdown, no code blocks:\\n{\\\"lead_score\\\": number between 0 and 100, \\\"priority_level\\\": \\\"High\\\" or \\\"Medium\\\" or \\\"Low\\\", \\\"decision_maker_probability\\\": \\\"High\\\" or \\\"Medium\\\" or \\\"Low\\\", \\\"company_size_estimate\\\": \\\"Enterprise\\\" or \\\"Mid-Market\\\" or \\\"SMB\\\" or \\\"Micro\\\", \\\"scoring_reason\\\": \\\"one sentence explaining the score\\\"}\" }] }) }}",
        "options": {}
      },
      "id": "clx03-0000-0000-0000-000000000005",
      "name": "Claude Score Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "2",
          "name": "Claude Anthropic"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude scoring response and extract score fields\nconst response = $input.item.json;\nconst lead = $('Split In Batches').item.json;\n\n// Extract text content from Claude API response\nconst rawText = response.content[0].text;\n\n// Parse the JSON — handle markdown-wrapped responses safely\nlet scoring;\ntry {\n  const cleaned = rawText\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n  scoring = JSON.parse(cleaned);\n} catch (e) {\n  scoring = {\n    lead_score: 0,\n    priority_level: 'Low',\n    decision_maker_probability: 'Low',\n    company_size_estimate: 'SMB',\n    scoring_reason: 'Manual review needed — AI parse error: ' + e.message\n  };\n}\n\nconst now = new Date().toISOString();\n\nreturn {\n  json: {\n    id: lead.id,\n    lead_score: typeof scoring.lead_score === 'number' ? scoring.lead_score : 0,\n    priority_level: scoring.priority_level || 'Low',\n    decision_maker_probability: scoring.decision_maker_probability || 'Low',\n    company_size_estimate: scoring.company_size_estimate || 'SMB',\n    scoring_reason: scoring.scoring_reason || '',\n    lead_status: 'Scored',\n    updated_at: now\n  }\n};"
      },
