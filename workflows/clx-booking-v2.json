        "jsCode": "// CLX Booking v2 — Prep Update Booked\n\nconst built = $('Build Booking Email').first().json;\n\nconst body = {\n  p_lead_id: built.id,\n  p_fields: {\n    interest_detected: true,\n    booking_email_sent: built.booking_email_sent,\n    booking_email_sent_at: built.booking_email_sent_at,\n    calendly_link: built.calendly_link,\n    lead_status: 'Booking Sent',\n    total_emails_sent: built.total_emails_sent,\n    last_email_sent_at: built.last_email_sent_at\n  }\n};\n\nconsole.log('PREP UPDATE:', JSON.stringify({ lead_id: built.id, status: body.p_fields.lead_status, path: 'booked' }));\n\nreturn [{ json: { ...built, rpc_body: JSON.stringify(body) } }];"
