    {
      "parameters": {
        "jsCode": "// CLX Booking v2 — Build Booking Email\n// Reads lead from Parse Interest Response (still has the full lead + interest\n// fields) and client config from Get Client Config. Uses .first() accessors\n// because the Has Email IF node and Get Client Config HTTP replaced $input.\n\nconst lead = $('Parse Interest Response').first().json;\nconst clientRow = ($('Get Client Config').first() || {}).json || {};\n\nconst clientName = clientRow.client_name || 'our team';\nconst calendlyUrl = clientRow.calendly_link || 'https://calendly.com/placeholder';\nconst notificationEmail = clientRow.notification_email || null;\nconst industry = (lead.industry || 'business').trim();\nconst prettyIndustry = industry.charAt(0).toUpperCase() + industry.slice(1);\n\nconst subject = `Let's find a time — Free ${prettyIndustry} Consultation`;\n\n// CASL (Canada's Anti-Spam Legislation) unsubscribe footer.\nconst caslFooter = '<br><br><hr style=\"border:none;border-top:1px solid #e0e0e0;margin:24px 0;\">' +\n  '<p style=\"font-size:11px;color:#999999;font-family:Arial,sans-serif;line-height:1.5;\">' +\n  'You are receiving this message because you replied to an earlier outreach ' +\n  'from ' + clientName + '. To unsubscribe, reply STOP or <a href=\"mailto:info@crystallux.org?subject=Unsubscribe\" style=\"color:#999999;\">click here</a>.<br>' +\n  'Sent by ' + clientName + ' via Crystallux AI | info@crystallux.org' +\n  '</p>';\n\nconst body = '<div style=\"font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#333333;max-width:600px;\">' +\n  '<p style=\"margin:0 0 16px 0;\">Hi ' + (lead.full_name || 'there') + ',</p>' +\n  '<p style=\"margin:0 0 16px 0;\">Thank you for your interest in ' + clientName + '. ' +\n  'I would love to find a time that works for you.</p>' +\n  '<p style=\"margin:0 0 16px 0;\">You can grab a slot directly here: ' +\n  '<a href=\"' + calendlyUrl + '\" style=\"color:#2c6cf5;\">' + calendlyUrl + '</a></p>' +\n  '<p style=\"margin:0 0 16px 0;\">It takes under a minute and you will get an instant confirmation.</p>' +\n  '<p style=\"margin:24px 0 0 0;color:#333333;\">Talk soon,<br><strong>' + clientName + '</strong></p>' +\n  caslFooter +\n  '</div>';\n\nconst now = new Date().toISOString();\n\nconsole.log('BUILD BOOKING:', JSON.stringify({ lead_id: lead.id, client_name: clientName, has_calendly: calendlyUrl !== 'https://calendly.com/placeholder' }));\n\nreturn [{\n  json: {\n    ...lead,\n    booking_subject: subject,\n    booking_body: body,\n    calendly_link: calendlyUrl,\n    client_name: clientName,\n    notification_email: notificationEmail,\n    booking_email_sent: true,\n    booking_email_sent_at: now,\n    lead_status: 'Booking Sent',\n    total_emails_sent: (Number(lead.total_emails_sent) || 0) + 1,\n    last_email_sent_at: now\n  }\n}];"
      },
      "id": "clx09-0000-0000-0000-000000000010",
      "name": "Build Booking Email",
      "type": "n8n-nodes-base.code",
