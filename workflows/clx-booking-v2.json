    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 512, messages: [{ role: 'user', content: 'You are a sales assistant for the Crystallux AI Sales Engine.\\n\\nAnalyze this reply from a prospect and determine if they are interested in learning more or booking a meeting.\\n\\nProspect: ' + $('Split In Batches').first().json.full_name + '\\nCompany: ' + $('Split In Batches').first().json.company + '\\nTheir reply: ' + ($('Split In Batches').first().json.reply_text || '').replace(/[\\n\\r]/g, ' ').replace(/\"/g, '\\\\\"') + '\\n\\nInterest signals include: yes, interested, sure, sounds good, tell me more, let\\'s talk, book a call, schedule, when are you free, how does this work, what\\'s the cost, can you show me, I\\'d like to learn more, send me details, let\\'s connect.\\n\\nNOT interested signals: no, not interested, remove me, unsubscribe, not now, maybe later, too busy, wrong person, stop emailing, please don\\'t contact me.\\n\\nReturn ONLY raw JSON no explanation no markdown:\\n{\\n  \"interest_detected\": true or false,\\n  \"confidence\": \"High\" or \"Medium\" or \"Low\",\\n  \"signal_type\": \"positive\" or \"negative\" or \"neutral\",\\n  \"recommended_action\": \"book_meeting\" or \"nurture\" or \"remove\"\\n}' }] }) }}",
        "options": {}
      },
      "id": "clx09-0000-0000-0000-000000000006",
      "name": "Claude Detect Interest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "name": "Claude Anthropic"
        }
      },
      "continueOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// CLX Booking v2 — Parse Interest Response\n\nconst lead = $('Split In Batches').first().json;\nconst response = $input.item.json;\n\nlet rawText = '';\nif (response && response.content && Array.isArray(response.content)) {\n  rawText = response.content.map(c => c.text || '').join('');\n} else if (response && typeof response.content === 'string') {\n  rawText = response.content;\n}\nrawText = rawText.replace(/```json\\s*/gi, '').replace(/```\\s*/gi, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(rawText);\n} catch (error) {\n  return [{\n    json: {\n      ...lead,\n      interest_detected: 'false',\n      confidence: 'Low',\n      signal_type: 'neutral',\n      recommended_action: 'nurture',\n      parse_error: error.message\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...lead,\n    interest_detected: String(parsed.interest_detected === true),\n    confidence: parsed.confidence || 'Low',\n    signal_type: parsed.signal_type || 'neutral',\n    recommended_action: parsed.recommended_action || 'nurture'\n  }\n}];"
      },
      "id": "clx09-0000-0000-0000-000000000007",
      "name": "Parse Interest Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1880,
        300
      ]
    },
