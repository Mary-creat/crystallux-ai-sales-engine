{
  "name": "CLX - Agent Memory Update v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "agent/memory-update",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "amu-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 400],
      "webhookId": "clx-agent-memory-update-001",
      "notes": "DEACTIVATED. Internal-call (INTERNAL_EMAIL_SECRET). Embeds the supplied summary via OpenAI text-embedding-3-small (1536-dim) and inserts to agent_memory. The pgvector ivfflat index handles cosine retrieval for future C5 conversation handler runs. Importance score defaults to 0.5; high-impact events (booking, escalation, complaint) should pass importance > 0.7."
    },
    {
      "parameters": {
        "jsCode": "const body = ($input.item.json && $input.item.json.body) || $input.item.json || {};\nconst secret = body.internal_secret || '';\nconst expected = process.env.INTERNAL_EMAIL_SECRET || '';\nif (!expected || secret !== expected) return { json: { _unauthorized: true, error: 'internal secret required' } };\nif (!body.client_id || !body.summary) return { json: { _empty: true, error: 'client_id and summary required' } };\nreturn { json: {\n  _authorized: true,\n  lead_id: body.lead_id || null,\n  client_id: body.client_id,\n  summary: String(body.summary).slice(0, 4000),\n  memory_type: body.memory_type || 'conversation_summary',\n  importance_score: parseFloat(body.importance_score) || 0.5,\n  source_action_id: body.source_action_id || null\n} };",
        "mode": "runOnceForEachItem"
      },
      "id": "amu-0002",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._authorized }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "amu-0003",
      "name": "IF Authorized",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/embeddings",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "={{ 'Bearer ' + $env.OPENAI_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ input: $json.summary, model: 'text-embedding-3-small' }) }}",
        "options": { "timeout": 30000 }
      },
      "id": "amu-0004",
      "name": "OpenAI Embed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 320],
      "continueOnFail": true,
      "alwaysOutputData": true,
      "notes": "OpenAI text-embedding-3-small produces 1536-dim vectors matching agent_memory.embedding column. Cost: ~$0.02 per 1M tokens, negligible per memory write. Same OPENAI_API_KEY used by clx-copilot-whisper-v1 (existing dormant workflow)."
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Validate').item.json;\nconst resp = $input.item.json || {};\nconst emb = (resp.data && resp.data[0] && resp.data[0].embedding) || null;\nif (!emb) return { json: { _failed: true, error: (resp.error && resp.error.message) || 'no_embedding' } };\nconst tokens = (resp.usage && resp.usage.total_tokens) || 0;\nreturn { json: {\n  insert_row: {\n    lead_id: ctx.lead_id,\n    client_id: ctx.client_id,\n    memory_type: ctx.memory_type,\n    content: ctx.summary,\n    embedding: emb,\n    importance_score: ctx.importance_score,\n    source_action_id: ctx.source_action_id\n  },\n  client_id: ctx.client_id,\n  tokens: tokens\n} };",
        "mode": "runOnceForEachItem"
      },
      "id": "amu-0005",
      "name": "Build Insert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._failed }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "amu-0006",
      "name": "IF Failed",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1360, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/agent_memory",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.insert_row) }}",
        "options": {}
      },
      "id": "amu-0007",
      "name": "Insert Memory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1620, 240],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/agent_costs",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ client_id: $('Build Insert').item.json.client_id, action_id: null, cost_type: 'embedding', units: $('Build Insert').item.json.tokens || 0, unit_cost_cents: 0.000002, vendor: 'openai', recorded_at: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "amu-0008",
      "name": "Log Cost",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1860, 240],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true }) }}",
        "options": { "responseCode": 200 }
      },
      "id": "amu-0009",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2100, 240]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'unauthorized' }) }}",
        "options": { "responseCode": "={{ $json._unauthorized ? 401 : ($json._failed ? 502 : 400) }}" }
      },
      "id": "amu-0010",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [880, 540]
    }
  ],
  "connections": {
    "Webhook":         { "main": [[ { "node": "Validate", "type": "main", "index": 0 } ]] },
    "Validate":        { "main": [[ { "node": "IF Authorized", "type": "main", "index": 0 } ]] },
    "IF Authorized":   { "main": [[ { "node": "OpenAI Embed", "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ]] },
    "OpenAI Embed":    { "main": [[ { "node": "Build Insert", "type": "main", "index": 0 } ]] },
    "Build Insert":    { "main": [[ { "node": "IF Failed", "type": "main", "index": 0 } ]] },
    "IF Failed":       { "main": [[ { "node": "Respond 4xx", "type": "main", "index": 0 } ], [ { "node": "Insert Memory", "type": "main", "index": 0 } ]] },
    "Insert Memory":   { "main": [[ { "node": "Log Cost", "type": "main", "index": 0 } ]] },
    "Log Cost":        { "main": [[ { "node": "Respond OK", "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
