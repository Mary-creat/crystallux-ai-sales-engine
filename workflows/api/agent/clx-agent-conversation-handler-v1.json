    "Merge Branches":        { "main": [[ { "node": "Build Claude Prompt", "type": "main", "index": 0 } ]] },
    "Build Claude Prompt":   { "main": [[ { "node": "Claude Reply", "type": "main", "index": 0 } ]] },
    "Claude Reply":          { "main": [[ { "node": "Parse Reply", "type": "main", "index": 0 } ]] },
