{
  "id": "clxAgentConversationHandlerV1",
  "name": "CLX - Agent Conversation Handler v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "agent/conversation-handler",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "ach-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 400],
      "webhookId": "clx-agent-conversation-handler-001",
      "notes": "DEACTIVATED. Internal-call (INTERNAL_EMAIL_SECRET). Triggered by Twilio status callback (B10) when a lead replies via WhatsApp/SMS. Looks up or creates an agent_conversations row, runs Claude with conversation context + memory + personality, decides reply OR escalate, sends via appropriate sender. Triggers C6 (memory update) on completion."
    },
    {
      "parameters": {
        "jsCode": "const body = ($input.item.json && $input.item.json.body) || $input.item.json || {};\nconst secret = body.internal_secret || '';\nconst expected = process.env.INTERNAL_EMAIL_SECRET || '';\nif (!expected || secret !== expected) return { json: { _unauthorized: true, error: 'internal secret required' } };\nconst channel = body.channel || 'sms';\nconst from = body.from;\nconst message = body.message;\nif (!from || !message) return { json: { _empty: true, error: 'from and message required' } };\nreturn { json: { _authorized: true, channel: channel, from_phone: String(from).replace(/^whatsapp:/, ''), message: String(message).slice(0, 2000), external_id: body.external_id || null } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-0002",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._authorized }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "ach-0003",
      "name": "IF Authorized",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/leads?phone=eq.' + encodeURIComponent($json.from_phone) + '&select=id,client_id,first_name,full_name,company,niche_name&limit=1' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ach-0004",
      "name": "Lookup Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Validate').item.json;\nconst rows = $input.item.json;\nconst lead = (Array.isArray(rows) ? rows[0] : rows) || {};\nif (!lead.id) return { json: { _no_lead: true, error: 'inbound from unknown phone' } };\nreturn { json: { lead: lead, ctx: ctx } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-0005",
      "name": "Resolve Lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._no_lead }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "ach-0006",
      "name": "IF No Lead",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1360, 320]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/agent_personalities?client_id=eq.' + encodeURIComponent($json.lead.client_id) + '&select=*&limit=1' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ach-0007",
      "name": "Fetch Personality",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1620, 240],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/agent_memory?lead_id=eq.' + encodeURIComponent($('Resolve Lead').item.json.lead.id) + '&order=importance_score.desc&limit=10&select=memory_type,content,importance_score' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ach-0008",
      "name": "Fetch Memory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1620, 380],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "notes": "Phase-3-MVP retrieval: top-importance memories, NOT vector similarity. Vector similarity requires embedding the inbound message first (extra Claude/OpenAI call). MVP shortcut: pull top 10 by importance_score. Phase 4 enhancement: embed message → vector search via pgvector ivfflat."
    },
    {
      "parameters": { "mode": "append", "numberInputs": 2 },
      "id": "ach-0009",
      "name": "Merge Branches",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1860, 320]
    },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) {\n  try {\n    const items = $(name).all().map(function (i) { return i.json; });\n    if (items.length === 1 && Array.isArray(items[0])) return items[0];\n    return items;\n  } catch (e) { return []; }\n};\nconst personalities = allOf('Fetch Personality');\nconst memories = allOf('Fetch Memory');\nconst rl = $('Resolve Lead').item.json;\nconst lead = rl.lead;\nconst ctx = rl.ctx;\nconst p = personalities[0] || { voice_tone: 'professional', formality_level: 'business_casual', vertical_context: lead.niche_name || 'service_industry', escalation_rules: {} };\n\nconst memorySummary = (memories || []).slice(0, 10).map(function (m) { return '- (' + m.memory_type + ') ' + (m.content || '').slice(0, 200); }).join('\\n') || '(no prior memory)';\n\nconst systemPrompt = [\n  'You are the Crystallux AI Sales Agent replying to an inbound message via ' + ctx.channel + '.',\n  'Lead: ' + (lead.first_name || (lead.full_name || '').split(' ')[0]) + ' at ' + (lead.company || 'their company'),\n  'Vertical: ' + (p.vertical_context || lead.niche_name || 'service_industry'),\n  'Tone: ' + (p.voice_tone || 'professional') + ' / ' + (p.formality_level || 'business_casual'),\n  '',\n  'Recent memory about this lead:',\n  memorySummary,\n  '',\n  'Output strictly JSON: { \"action\": \"reply\" | \"escalate\", \"reply\": \"<text>\", \"reason_if_escalate\": \"<text>\" }',\n  '',\n  'Rules:',\n  '- Replies must be SHORT for SMS/WhatsApp (under 320 chars). Match tone.',\n  '- Escalate if: lead asks specific pricing, asks to talk to a human, expresses anger or frustration, asks legal/compliance question, or anything that violates personality.escalation_rules.',\n  '- Never make up product details or carrier names. Never quote a price.',\n  '- If escalating, reply field can still acknowledge \"thanks, getting someone to follow up\" — humans take it from there.'\n].join('\\n');\n\nreturn { json: {\n  lead_id: lead.id,\n  client_id: lead.client_id,\n  channel: ctx.channel,\n  inbound_message: ctx.message,\n  claude_payload: {\n    model: 'claude-sonnet-4-5-20250929',\n    max_tokens: 500,\n    temperature: 0.3,\n    system: systemPrompt,\n    messages: [ { role: 'user', content: ctx.message } ]\n  }\n} };",
        "mode": "runOnceForAllItems"
      },
      "id": "ach-0010",
      "name": "Build Claude Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2100, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.claude_payload) }}",
        "options": { "timeout": 30000 }
      },
      "id": "ach-0011",
      "name": "Claude Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2340, 320],
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Build Claude Prompt').item.json;\nconst resp = $input.item.json || {};\nlet textOut = '';\ntry { textOut = (resp.content && resp.content[0] && resp.content[0].text) || ''; } catch (e) {}\nlet parsed = null;\ntry { parsed = JSON.parse(String(textOut).replace(/```json|```/g, '').trim()); } catch (e) {}\nif (!parsed) parsed = { action: 'escalate', reply: 'Thanks — getting someone to follow up shortly.', reason_if_escalate: 'parse_failed' };\nreturn { json: {\n  lead_id: ctx.lead_id,\n  client_id: ctx.client_id,\n  channel: ctx.channel,\n  inbound_message: ctx.inbound_message,\n  action: parsed.action || 'reply',\n  reply: parsed.reply || '',\n  reason: parsed.reason_if_escalate || ''\n} };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-0012",
      "name": "Parse Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2580, 320]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.channel }}", "rightValue": "whatsapp", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "whatsapp" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.channel }}", "rightValue": "sms", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "sms" }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "id": "ach-0013",
      "name": "Switch Channel",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [2820, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.N8N_INTERNAL_BASE || 'http://localhost:5678') + '/webhook/messaging/whatsapp-send' }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ internal_secret: $env.INTERNAL_EMAIL_SECRET, lead_id: $json.lead_id, client_id: $json.client_id, content: $json.reply }) }}",
        "options": { "timeout": 15000 }
      },
      "id": "ach-0014",
      "name": "Send WhatsApp Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3060, 220],
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.N8N_INTERNAL_BASE || 'http://localhost:5678') + '/webhook/messaging/sms-send' }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ internal_secret: $env.INTERNAL_EMAIL_SECRET, lead_id: $json.lead_id, client_id: $json.client_id, content: $json.reply }) }}",
        "options": { "timeout": 15000 }
      },
      "id": "ach-0015",
      "name": "Send SMS Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3060, 380],
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.N8N_INTERNAL_BASE || 'http://localhost:5678') + '/webhook/agent/memory-update' }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ internal_secret: $env.INTERNAL_EMAIL_SECRET, lead_id: $('Parse Reply').item.json.lead_id, client_id: $('Parse Reply').item.json.client_id, summary: 'Inbound: ' + $('Parse Reply').item.json.inbound_message + ' | Outbound: ' + $('Parse Reply').item.json.reply, memory_type: 'conversation_summary' }) }}",
        "options": { "timeout": 5000 }
      },
      "id": "ach-0016",
      "name": "Trigger Memory Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3300, 320],
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, action: $('Parse Reply').item.json.action }) }}",
        "options": { "responseCode": 200 }
      },
      "id": "ach-0017",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [3540, 320]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'unauthorized' }) }}",
        "options": { "responseCode": "={{ $json._unauthorized ? 401 : 400 }}" }
      },
      "id": "ach-0018",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [880, 540]
    }
  ],
  "connections": {
    "Webhook":               { "main": [[ { "node": "Validate", "type": "main", "index": 0 } ]] },
