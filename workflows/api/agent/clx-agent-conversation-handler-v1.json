    "Switch Channel":        { "main": [[ { "node": "Send WhatsApp Reply", "type": "main", "index": 0 } ], [ { "node": "Send SMS Reply", "type": "main", "index": 0 } ], [ { "node": "Trigger Memory Update", "type": "main", "index": 0 } ]] },
    "Send WhatsApp Reply":   { "main": [[ { "node": "Trigger Memory Update", "type": "main", "index": 0 } ]] },
    "Send SMS Reply":        { "main": [[ { "node": "Trigger Memory Update", "type": "main", "index": 0 } ]] },
    "Trigger Memory Update": { "main": [[ { "node": "Respond OK", "type": "main", "index": 0 } ]] }
