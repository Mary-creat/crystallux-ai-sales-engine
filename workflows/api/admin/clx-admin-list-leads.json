{
  "name": "CLX - Admin List Leads v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "admin/list-leads",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "adm-ll-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "clx-admin-list-leads-001"
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { ok: false, status: 401, error: 'Missing session token' } };\nconst f = (body.filters || {});\nconst limit = Math.min(Math.max(parseInt(f.limit, 10) || 50, 1), 500);\nlet qs = 'select=id,company,industry,city,lead_status,lead_score,phone,source,client_id,client_name,updated_at&order=updated_at.desc&limit=' + limit;\nif (f.status && f.status !== 'all') qs += '&lead_status=eq.' + encodeURIComponent(f.status);\nif (f.client_id) qs += '&client_id=eq.' + encodeURIComponent(f.client_id);\nreturn { json: { token, qs } };",
        "mode": "runOnceForEachItem"
      },
      "id": "adm-ll-0002",
      "name": "Extract Inputs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }",
        "options": {}
      },
      "id": "adm-ll-0003",
      "name": "Validate Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.id || rows.user_id) ? rows : null);\nif (!row) return { json: { ok: false, status: 401, error: 'Invalid or expired session' } };\nif (row.user_role !== 'admin') return { json: { ok: false, status: 403, error: 'Admin access required' } };\nreturn { json: { ok: true, qs: $('Extract Inputs').item.json.qs } };",
        "mode": "runOnceForEachItem"
      },
      "id": "adm-ll-0004",
      "name": "Check Admin",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "adm-ll-0005",
      "name": "IF Admin OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/leads?' + $json.qs }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "adm-ll-0006",
      "name": "Query Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, leads: $json }) }}",
        "options": { "responseCode": 200 }
      },
      "id": "adm-ll-0007",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1580, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}",
        "options": { "responseCode": "={{ $json.status || 401 }}" }
      },
      "id": "adm-ll-0008",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 420]
    }
  ],
  "connections": {
    "Webhook":          { "main": [[ { "node": "Extract Inputs",   "type": "main", "index": 0 } ]] },
    "Extract Inputs":   { "main": [[ { "node": "Validate Session", "type": "main", "index": 0 } ]] },
    "Validate Session": { "main": [[ { "node": "Check Admin",      "type": "main", "index": 0 } ]] },
    "Check Admin":      { "main": [[ { "node": "IF Admin OK",      "type": "main", "index": 0 } ]] },
    "IF Admin OK":      { "main": [
                                   [ { "node": "Query Leads",      "type": "main", "index": 0 } ],
                                   [ { "node": "Respond 4xx",      "type": "main", "index": 0 } ]
                                 ] },
    "Query Leads":      { "main": [[ { "node": "Respond OK",       "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
