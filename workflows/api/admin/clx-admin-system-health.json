    {
      "parameters": {
        "jsCode": "// Pull counts from PostgREST aggregate (?select=count -> [{count: N}]) and\n// shape the dashboard KPI response. allOf() collects multi-row responses\n// safely under both n8n auto-split and non-split behaviours — see\n// clx-admin-client-detail.json for the rationale.\nconst allOf = function (name) {\n  try {\n    const items = $(name).all().map(function (i) { return i.json; });\n    if (items.length === 1 && Array.isArray(items[0])) return items[0];\n    return items;\n  } catch (e) { return []; }\n};\nconst readCountRow = function (rows) {\n  if (rows.length && rows[0] && rows[0].count != null) return Number(rows[0].count);\n  return null;\n};\n\nconst totalLeads = readCountRow(allOf('Count Leads'));\nconst bookedWeek = readCountRow(allOf('Count Booked Week'));\n\nconst PLAN_PRICES = { founding_1997:1997, standard_2497:2497, construction_1497:1497, moving_997:997, cleaning_997:997, salon_997:997, intelligence_3997:3997 };\nconst clients = allOf('Active Clients');\nlet mrr = 0; let activeCount = 0;\nclients.forEach(function (c) {\n  if (c.subscription_status === 'active' || c.subscription_status === 'trialing') {\n    activeCount += 1;\n    mrr += PLAN_PRICES[c.subscription_plan] || (c.monthly_retainer || 0);\n  }\n});\n\nconst errorRows = allOf('Errors 24h');\nlet errors24h = 0;\nerrorRows.forEach(function (r) { errors24h += (Number(r.errors) || 0); });\n\nreturn { json: {\n  ok: true,\n  total_leads: totalLeads,\n  active_clients: activeCount,\n  booked_this_week: bookedWeek,\n  errors_24h: errors24h,\n  mrr_cad: mrr\n} };",
        "mode": "runOnceForAllItems"
      },
      "id": "adm-sh-0010",
      "name": "Shape Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1820, 460]
    },
