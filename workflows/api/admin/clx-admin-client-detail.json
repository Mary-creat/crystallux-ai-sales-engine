      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 460],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/leads?client_id=eq.' + encodeURIComponent($('Check Admin').item.json.client_id) + '&select=lead_status' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "adm-cd-0009",
      "name": "Query Lead Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 620],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Defensive read of each parallel branch — any single Supabase call failing\n// (transient 5xx, RLS hiccup, schema mismatch) used to crash this whole node\n// with 'Node X hasn't been executed'. safeNode() degrades the bad branch to\n// null/[]; the rest of the panel still renders.\nconst safeNode = (name) => { try { return $(name).first().json; } catch (e) { return null; } };\nconst toArr = (raw) => {\n  if (Array.isArray(raw)) return raw;\n  if (raw && typeof raw === 'object' && Object.keys(raw).length) return [raw];\n  return [];\n};\nconst clientArr = toArr(safeNode('Query Client'));\nconst client = clientArr[0] || null;\nif (!client) return { json: { ok: true, client: null } };\nconst statsArr = toArr(safeNode('Query Lead Stats'));\nconst recentArr = toArr(safeNode('Query Recent Leads'));\nconst counts = {};\nstatsArr.forEach(r => { const s = r.lead_status || 'New Lead'; counts[s] = (counts[s] || 0) + 1; });\nconst stats = {\n  total_leads: statsArr.length,\n  contacted: counts['Contacted'] || 0,\n  replied:   counts['Replied']   || 0,\n  booked_mtd: counts['Booked']   || 0\n};\nreturn { json: { ok: true, client, stats, recent_leads: recentArr } };",
        "mode": "runOnceForAllItems"
      },
      "id": "adm-cd-0010",
      "name": "Shape Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1820, 460]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseCode": 200 }
      },
      "id": "adm-cd-0011",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2060, 460]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}",
        "options": { "responseCode": "={{ $json.status || 401 }}" }
      },
      "id": "adm-cd-0012",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [880, 200]
    }
  ],
