{
  "id": "wfAdminChatHistoryV1",
  "name": "CLX - Admin Chat History v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "admin/chat/history",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "ach-h-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "clx-admin-chat-history-001"
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { ok: false, status: 401, error: 'Missing session token' } };\nreturn { json: { token } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-h-0002",
      "name": "Extract Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "ach-h-0003",
      "name": "Validate Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.id || rows.user_id) ? rows : null);\nif (!row) return { json: { ok: false, status: 401, error: 'Invalid or expired session' } };\nif (row.user_role !== 'admin') return { json: { ok: false, status: 403, error: 'Admin access required' } };\nreturn { json: { ok: true, user_id: row.user_id || row.id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-h-0004",
      "name": "Check Admin",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "ach-h-0005",
      "name": "IF Admin OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/find_or_create_active_chat_session",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"p_user_id\": \"{{ $json.user_id }}\" }",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "ach-h-0006",
      "name": "Resolve Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "// RPC returns a uuid string (with quotes) or an array; normalize.\nconst raw = $input.item.json;\nlet sessionId = null;\nif (typeof raw === 'string') sessionId = raw.replace(/\"/g, '');\nelse if (Array.isArray(raw) && raw.length) sessionId = raw[0];\nelse if (raw && raw.find_or_create_active_chat_session) sessionId = raw.find_or_create_active_chat_session;\nif (!sessionId) return { json: { ok: false, status: 500, error: 'Could not resolve chat session' } };\nreturn { json: { session_id: sessionId } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ach-h-0007",
      "name": "Normalize Session",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 220]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/admin_chat_messages?select=role,content,tool_calls,tool_results,created_at&session_id=eq.' + $json.session_id + '&order=created_at.asc&limit=40' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Accept", "value": "application/json" }] },
        "options": {}
      },
      "id": "ach-h-0008",
      "name": "Fetch Messages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) {\n  try {\n    const items = $(name).all().map(function (i) { return i.json; });\n    if (items.length === 1 && Array.isArray(items[0])) return items[0];\n    return items;\n  } catch (e) { return []; }\n};\nconst sess = $('Normalize Session').first().json;\nconst rows = allOf('Fetch Messages');\nconst messages = rows.filter(function (r) {\n  return r && (r.role === 'user' || r.role === 'assistant');\n}).map(function (r) {\n  return { role: r.role, content: r.content || '', ts: r.created_at };\n});\nreturn { json: { ok: true, data: { session_id: sess.session_id, messages: messages } } };",
        "mode": "runOnceForAllItems"
      },
      "id": "ach-h-0009",
      "name": "Shape Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2020, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {
          "responseHeaders": {
            "entries": [{ "name": "Cache-Control", "value": "no-store" }]
          }
        }
      },
      "id": "ach-h-0010",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2260, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: false, error: $json.error || 'Unauthorized', status: $json.status || 401 } }}",
        "options": { "responseCode": "={{ $json.status || 401 }}" }
      },
      "id": "ach-h-0011",
      "name": "Respond Unauthorized",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 500]
    }
  ],
  "connections": {
    "Webhook":          { "main": [[{ "node": "Extract Token",    "type": "main", "index": 0 }]] },
    "Extract Token":    { "main": [[{ "node": "Validate Session", "type": "main", "index": 0 }]] },
    "Validate Session": { "main": [[{ "node": "Check Admin",      "type": "main", "index": 0 }]] },
    "Check Admin":      { "main": [[{ "node": "IF Admin OK",      "type": "main", "index": 0 }]] },
    "IF Admin OK": {
      "main": [
        [ { "node": "Resolve Session",      "type": "main", "index": 0 } ],
        [ { "node": "Respond Unauthorized", "type": "main", "index": 0 } ]
      ]
    },
    "Resolve Session":   { "main": [[{ "node": "Normalize Session", "type": "main", "index": 0 }]] },
    "Normalize Session": { "main": [[{ "node": "Fetch Messages",    "type": "main", "index": 0 }]] },
    "Fetch Messages":    { "main": [[{ "node": "Shape Response",    "type": "main", "index": 0 }]] },
    "Shape Response":    { "main": [[{ "node": "Respond",           "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false,
  "version": 1
}
