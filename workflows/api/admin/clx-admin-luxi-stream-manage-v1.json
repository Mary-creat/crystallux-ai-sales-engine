{
  "id": "wfAdminLuxiStreamManageV1",
  "name": "CLX - Admin LUXI Stream Manage v1",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "admin/luxi/stream", "responseMode": "responseNode", "options": {} },
      "id": "alsm-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 360],
      "webhookId": "clx-admin-luxi-stream-manage-001",
      "notes": "DEACTIVATED. Admin-gated. Start/end a LUXI live stream session. Body: { action:'start'|'end', platforms?:[], title?, auction_id?, rtmp_ingest_url?, stream_key?, watch_urls?:{}, session_id? }. Transport (Restream/HeyGen/OBS) is external; this orchestrates the session + LIVE badge."
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { ok: false, status: 401, error: 'Missing session token' } };\nconst action = String(body.action || '').toLowerCase().trim();\nif (action !== 'start' && action !== 'end') return { json: { ok: false, status: 400, error: \"action must be 'start' or 'end'\" } };\nreturn { json: {\n  token: token, action: action,\n  platforms: Array.isArray(body.platforms) ? body.platforms : [],\n  title: String(body.title || '').slice(0, 200),\n  auction_id: body.auction_id || null,\n  rtmp_ingest_url: String(body.rtmp_ingest_url || '').slice(0, 500),\n  stream_key: String(body.stream_key || '').slice(0, 500),\n  watch_urls: (body.watch_urls && typeof body.watch_urls === 'object') ? body.watch_urls : {},\n  session_id: body.session_id || null\n} };",
        "mode": "runOnceForEachItem"
      },
      "id": "alsm-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 360]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "alsm-0003", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [640, 360],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.user_id || rows.id) ? rows : null);\nif (!row) return { json: { ok: false, status: 401, error: 'Invalid or expired session' } };\nif (row.user_role !== 'admin') return { json: { ok: false, status: 403, error: 'Admin access required' } };\nconst x = $('Extract').item.json;\nreturn { json: Object.assign({ ok: true }, x) };",
        "mode": "runOnceForEachItem"
      },
      "id": "alsm-0004", "name": "Check Admin", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [880, 360]
    },
    {
      "parameters": {
        "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [{ "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }], "combinator": "and" }
      },
      "id": "alsm-0005", "name": "IF Admin OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1100, 360]
    },
    {
      "parameters": {
        "rules": { "values": [
          { "outputKey": "start", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 }, "conditions": [{ "id": "c1", "leftValue": "={{ $json.action }}", "rightValue": "start", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } },
          { "outputKey": "end", "conditions": { "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 }, "conditions": [{ "id": "c1", "leftValue": "={{ $json.action }}", "rightValue": "end", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" } }
        ] }, "options": {}
      },
      "id": "alsm-0006", "name": "Switch Action", "type": "n8n-nodes-base.switch", "typeVersion": 3.2, "position": [1320, 360]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/luxi_stream_start",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }, { "name": "Accept", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ p_platforms: $json.platforms, p_title: $json.title, p_auction_id: $json.auction_id, p_rtmp: $json.rtmp_ingest_url, p_stream_key: $json.stream_key, p_watch_urls: $json.watch_urls }) }}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "alsm-0007", "name": "Start RPC", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1560, 240],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/luxi_stream_end",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }, { "name": "Accept", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ p_session_id: $json.session_id }) }}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "alsm-0008", "name": "End RPC", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1560, 460],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "let r = $input.item.json; if (Array.isArray(r)) r = r[0] || {};\nif (r == null || typeof r !== 'object') r = { ok: false, status: 500, error: 'Unexpected DB response' };\nif (r.ok === false) return { json: { ok: false, status: r.status || 500, error: r.error || 'Stream action failed' } };\nreturn { json: Object.assign({ ok: true, status: 200 }, r) };",
        "mode": "runOnceForEachItem"
      },
      "id": "alsm-0009", "name": "Shape", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1800, 360]
    },
    {
      "parameters": {
        "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseCode": "={{ $json.status || 200 }}" }
      },
      "id": "alsm-0010", "name": "Respond", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2040, 360]
    },
    {
      "parameters": {
        "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}",
        "options": { "responseCode": "={{ $json.status || 401 }}" }
      },
      "id": "alsm-0011", "name": "Respond Error", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1320, 600]
    }
  ],
  "connections": {
    "Webhook":          { "main": [[{ "node": "Extract",          "type": "main", "index": 0 }]] },
    "Extract":          { "main": [[{ "node": "Validate Session", "type": "main", "index": 0 }]] },
    "Validate Session": { "main": [[{ "node": "Check Admin",      "type": "main", "index": 0 }]] },
    "Check Admin":      { "main": [[{ "node": "IF Admin OK",      "type": "main", "index": 0 }]] },
    "IF Admin OK": { "main": [
      [{ "node": "Switch Action", "type": "main", "index": 0 }],
      [{ "node": "Respond Error", "type": "main", "index": 0 }]
    ] },
    "Switch Action": { "main": [
      [{ "node": "Start RPC", "type": "main", "index": 0 }],
      [{ "node": "End RPC",   "type": "main", "index": 0 }]
    ] },
    "Start RPC": { "main": [[{ "node": "Shape",   "type": "main", "index": 0 }]] },
    "End RPC":   { "main": [[{ "node": "Shape",   "type": "main", "index": 0 }]] },
    "Shape":     { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
