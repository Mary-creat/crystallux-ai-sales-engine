{
  "name": "CLX - Sentinel Credential Rotate Record v1",
  "nodes": [
    { "parameters": { "httpMethod": "POST", "path": "api/sentinel/security/credential-rotate", "responseMode": "responseNode", "options": {} }, "id": "scrr-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400], "webhookId": "clx-sentinel-credential-rotate-record-001", "notes": "DEACTIVATED. Admin session. Records that Mary just rotated a credential — sets last_rotated_at = now(), which slides next_rotation_due (a generated column) forward. Optionally accepts a notes update." },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401 } };\nif (!body.credential_name) return { json: { _empty: true, status: 400, error: 'credential_name required' } };\nreturn { json: { token, body } };",
        "mode": "runOnceForEachItem"
      },
      "id": "scrr-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [440, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._unauthorized || $json._empty }}", "rightValue": true, "operator": { "type": "boolean", "operation": "notEquals" } } ], "combinator": "and" } }, "id": "scrr-0003", "name": "IF Args OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [680, 400] },
    { "parameters": { "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth", "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] }, "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }", "options": {} }, "id": "scrr-0004", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [920, 320], "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } } },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401 } };\nif (row.user_role !== 'admin') return { json: { _unauthorized: true, status: 403, error: 'admin role required' } };\nconst body = $('Extract').first().json.body;\nconst payload = { last_rotated_at: new Date().toISOString(), updated_at: new Date().toISOString() };\nif (body.notes !== undefined) payload.notes = body.notes;\nreturn { json: { _ok: true, credential_name: body.credential_name, payload: payload, performed_by: row.user_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "scrr-0005", "name": "Check Admin", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1160, 320]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } }, "id": "scrr-0006", "name": "IF Admin", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1400, 320] },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/sentinel_credential_inventory?credential_name=eq.{{ encodeURIComponent($json.credential_name) }}",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=representation" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.payload) }}",
        "options": {}
      },
      "id": "scrr-0007", "name": "Update Credential", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1640, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/sentinel_actions",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=minimal" } ] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"module_name\": \"security_monitoring\", \"action_type\": \"credential_rotated\", \"target_resource\": \"{{ $('Check Admin').first().json.credential_name }}\", \"action_data\": {{ JSON.stringify($('Check Admin').first().json.payload) }}, \"triggered_by\": \"human:{{ $('Check Admin').first().json.performed_by }}\", \"status\": \"succeeded\", \"executed_at\": \"{{ $now }}\", \"human_approved\": true, \"approved_by\": \"{{ $('Check Admin').first().json.performed_by }}\", \"approved_at\": \"{{ $now }}\" }",
        "options": { "continueOnFail": true }
      },
      "id": "scrr-0008", "name": "Log Action", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1880, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const row = $('Update Credential').first().json;\nconst credential = Array.isArray(row) ? row[0] : row;\nreturn { json: { ok: true, credential: credential } };",
        "mode": "runOnceForAllItems"
      },
      "id": "scrr-0009", "name": "Shape OK", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2120, 220]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "scrr-0010", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2360, 220] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}", "options": { "responseCode": "={{ $json.status || 401 }}" } }, "id": "scrr-0011", "name": "Respond 4xx", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1160, 480] }
  ],
  "connections": {
    "Webhook":          { "main": [[ { "node": "Extract", "type": "main", "index": 0 } ]] },
    "Extract":          { "main": [[ { "node": "IF Args OK", "type": "main", "index": 0 } ]] },
