    "IF OK":                 { "main": [ [ { "node": "Fetch Workflow Health", "type": "main", "index": 0 }, { "node": "Fetch Endpoint Health", "type": "main", "index": 0 }, { "node": "Fetch Health Alerts", "type": "main", "index": 0 }, { "node": "Fetch Breakers", "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ] ] },
    "Fetch Workflow Health": { "main": [[ { "node": "Merge Branches", "type": "main", "index": 0 } ]] },
    "Fetch Endpoint Health": { "main": [[ { "node": "Merge Branches", "type": "main", "index": 1 } ]] },
    "Fetch Health Alerts":   { "main": [[ { "node": "Merge Branches", "type": "main", "index": 2 } ]] },
    "Fetch Breakers":        { "main": [[ { "node": "Merge Branches", "type": "main", "index": 3 } ]] },
    "Merge Branches":        { "main": [[ { "node": "Aggregate", "type": "main", "index": 0 } ]] },
    "Aggregate":             { "main": [[ { "node": "Respond OK", "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
