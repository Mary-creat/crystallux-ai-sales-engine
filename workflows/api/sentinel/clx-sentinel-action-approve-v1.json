    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json.plus.kind }}", "rightValue": "breaker_patch", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" } }, "id": "saa-0012", "name": "IF breaker_patch", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [2320, 280] },
