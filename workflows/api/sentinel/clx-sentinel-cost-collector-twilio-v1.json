{
  "name": "CLX - Sentinel Cost Collector Twilio v1",
  "nodes": [
    { "parameters": { "rule": { "interval": [ { "field": "cronExpression", "expression": "0 6 * * *" } ] } }, "id": "sct-0001", "name": "Schedule 06:00 Daily", "type": "n8n-nodes-base.scheduleTrigger", "typeVersion": 1.2, "position": [200, 200] },
    { "parameters": { "httpMethod": "POST", "path": "api/sentinel/cost/collect-twilio", "responseMode": "responseNode", "options": {} }, "id": "sct-0002", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400], "webhookId": "clx-sentinel-cost-collector-twilio-001", "notes": "DEACTIVATED. Cron 06:00 daily + manual webhook. Sums yesterday's messages_sent rows where channel IN (sms, whatsapp) — those are exclusively Twilio. cost_cents is already recorded per-message. Upserts sentinel_cost_tracking." },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/messages_sent?channel=in.(sms,whatsapp)&sent_at=gte.' + new Date(Date.now() - 86400000).toISOString().slice(0,10) + 'T00:00:00Z&sent_at=lt.' + new Date().toISOString().slice(0,10) + 'T00:00:00Z&select=channel,cost_cents,status' }}",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": { "continueOnFail": true }
      },
      "id": "sct-0003", "name": "Fetch Twilio Messages", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [480, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($input.item.json) ? $input.item.json : [];\nlet costCents = 0;\nconst byChannel = {};\nrows.forEach(function (r) {\n  const c = parseInt(r.cost_cents) || 0;\n  costCents += c;\n  byChannel[r.channel] = (byChannel[r.channel] || { count: 0, cost_cents: 0 });\n  byChannel[r.channel].count += 1;\n  byChannel[r.channel].cost_cents += c;\n});\nconst tracking_date = new Date(Date.now() - 86400000).toISOString().slice(0,10);\nreturn { json: { row: { tracking_date, service_name: 'twilio', spend_cents: costCents, data_source: 'internal_log', usage_metrics: { messages_total: rows.length, by_channel: byChannel }, notes: 'Computed from messages_sent.cost_cents where channel IN (sms, whatsapp).' } } };",
        "mode": "runOnceForAllItems"
      },
      "id": "sct-0004", "name": "Compute Spend", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [720, 300]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/sentinel_cost_tracking?on_conflict=tracking_date,service_name",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "resolution=merge-duplicates,return=representation" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.row) }}",
        "options": {}
      },
      "id": "sct-0005", "name": "Upsert Spend Row", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [960, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    { "parameters": { "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : rows;\nreturn { json: { ok: true, service: 'twilio', tracking_date: row.tracking_date, spend_cents: row.spend_cents, usage: row.usage_metrics } };", "mode": "runOnceForEachItem" }, "id": "sct-0006", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1200, 300] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "sct-0007", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1440, 300] }
  ],
  "connections": {
    "Schedule 06:00 Daily": { "main": [[ { "node": "Fetch Twilio Messages", "type": "main", "index": 0 } ]] },
    "Webhook":              { "main": [[ { "node": "Fetch Twilio Messages", "type": "main", "index": 0 } ]] },
    "Fetch Twilio Messages":{ "main": [[ { "node": "Compute Spend",          "type": "main", "index": 0 } ]] },
    "Compute Spend":        { "main": [[ { "node": "Upsert Spend Row",       "type": "main", "index": 0 } ]] },
    "Upsert Spend Row":     { "main": [[ { "node": "Shape Response",         "type": "main", "index": 0 } ]] },
    "Shape Response":       { "main": [[ { "node": "Respond OK",             "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
