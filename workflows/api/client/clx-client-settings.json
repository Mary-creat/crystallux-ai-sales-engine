{
  "name": "CLX - Client Settings v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "client/settings",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "cli-st-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "clx-client-settings-001"
    },
    {
      "parameters": {
        "jsCode": "// Single endpoint handles both reads and writes. A read request has\n// no notification fields in the body; a write has at least one. We\n// strip any client_id the caller sends (defence-in-depth — server\n// re-derives from the session row).\nconst headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { ok: false, status: 401, error: 'Missing session token' } };\n// Detect intent\nconst writeKeys = ['notification_email','daily_digest_opt_in','booking_alerts_opt_in'];\nconst isWrite = writeKeys.some(k => Object.prototype.hasOwnProperty.call(body, k));\nconst payload = {};\nif (isWrite) {\n  if (typeof body.notification_email === 'string') {\n    const e = String(body.notification_email).trim().toLowerCase();\n    if (e && !/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/.test(e)) return { json: { ok: false, status: 400, error: 'Invalid notification email' } };\n    payload.notification_email = e || null;\n  }\n  if (typeof body.daily_digest_opt_in === 'boolean')   payload.daily_digest_opt_in   = body.daily_digest_opt_in;\n  if (typeof body.booking_alerts_opt_in === 'boolean') payload.booking_alerts_opt_in = body.booking_alerts_opt_in;\n}\nreturn { json: { token, isWrite, payload } };",
        "mode": "runOnceForEachItem"
      },
      "id": "cli-st-0002",
      "name": "Parse Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }",
        "options": {}
      },
      "id": "cli-st-0003",
      "name": "Validate Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.id || rows.user_id) ? rows : null);\nconst input = $('Parse Request').item.json;\nif (!row) return { json: { ok: false, status: 401, error: 'Invalid or expired session' } };\nif (row.user_role !== 'client' && row.user_role !== 'team_member') return { json: { ok: false, status: 403, error: 'Client access required' } };\nif (!row.client_id) return { json: { ok: false, status: 403, error: 'No client mapped to session' } };\n// team_members are read-only for now — only the primary client login can mutate prefs\nif (input.isWrite && row.user_role !== 'client') return { json: { ok: false, status: 403, error: 'Only the primary account can change settings' } };\nreturn { json: { ok: true, client_id: row.client_id, isWrite: input.isWrite, payload: input.payload } };",
        "mode": "runOnceForEachItem"
      },
      "id": "cli-st-0004",
      "name": "Check Client",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "cli-st-0005",
      "name": "IF Client OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.isWrite }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "cli-st-0006",
      "name": "IF Write",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1340, 220]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/clients?id=eq.' + encodeURIComponent($json.client_id) }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
