{
  "id": "clxWhatsappSendV1",
  "name": "CLX - WhatsApp Send v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "messaging/whatsapp-send",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "ws-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 400],
      "webhookId": "clx-whatsapp-send-001",
      "notes": "DEACTIVATED. Internal-call (INTERNAL_EMAIL_SECRET). Twilio WhatsApp send wrapper. Reads lead.phone + agent_channels_enabled.configuration for client's Twilio WA sender (whatsapp:+14...). Inserts to messages_sent + agent_actions + agent_costs. DORMANT until Meta WhatsApp Business approval clears for the client's Twilio WA sender."
    },
    {
      "parameters": {
        "jsCode": "const body = ($input.item.json && $input.item.json.body) || $input.item.json || {};\nconst secret = body.internal_secret || '';\nconst expected = process.env.INTERNAL_EMAIL_SECRET || '';\nif (!expected || secret !== expected) return { json: { _unauthorized: true, error: 'internal secret required' } };\nif (!body.lead_id || !body.client_id || !body.content) return { json: { _empty: true, error: 'lead_id, client_id, content required' } };\nreturn { json: {\n  _authorized: true,\n  lead_id: body.lead_id,\n  client_id: body.client_id,\n  content: String(body.content).slice(0, 1500),\n  video_render_id: body.video_render_id || null,\n  agent_action_id: body.agent_action_id || null\n} };",
        "mode": "runOnceForEachItem"
      },
      "id": "ws-0002",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._authorized }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "ws-0003",
      "name": "IF Authorized",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/leads?id=eq.' + encodeURIComponent($json.lead_id) + '&select=phone&limit=1' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ws-0004",
      "name": "Fetch Lead Phone",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/agent_channels_enabled?client_id=eq.' + encodeURIComponent($('Validate').item.json.client_id) + '&channel=eq.whatsapp&enabled=eq.true&select=configuration&limit=1' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ws-0005",
      "name": "Fetch WA Config",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 480],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": { "mode": "append", "numberInputs": 2 },
      "id": "ws-0006",
      "name": "Merge Branches",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1140, 400]
    },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) {\n  try {\n    const items = $(name).all().map(function (i) { return i.json; });\n    if (items.length === 1 && Array.isArray(items[0])) return items[0];\n    return items;\n  } catch (e) { return []; }\n};\nconst leads = allOf('Fetch Lead Phone');\nconst configs = allOf('Fetch WA Config');\nconst lead = leads[0] || {};\nconst cfg = (configs[0] && configs[0].configuration) || {};\nconst ctx = $('Validate').item.json;\nconst phone = lead.phone;\nif (!phone) return { json: { _no_phone: true, error: 'lead has no phone' } };\nconst from = cfg.twilio_whatsapp_from || ('whatsapp:' + (process.env.TWILIO_WHATSAPP_FROM || '+14000000000'));\nconst to = phone.indexOf('whatsapp:') === 0 ? phone : ('whatsapp:' + phone.replace(/[^+0-9]/g, ''));\nconst statusCb = (process.env.N8N_PUBLIC_BASE || 'https://automation.crystallux.org') + '/webhook/twilio/status';\nreturn { json: {\n  twilio_account_sid: process.env.TWILIO_ACCOUNT_SID,\n  twilio_form: { To: to, From: from, Body: ctx.content, StatusCallback: statusCb },\n  ctx: ctx\n} };",
        "mode": "runOnceForAllItems"
      },
      "id": "ws-0007",
      "name": "Build Twilio Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1380, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json._no_phone }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "ws-0008",
      "name": "IF No Phone",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1620, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.twilio.com/2010-04-01/Accounts/' + $json.twilio_account_sid + '/Messages.json' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/x-www-form-urlencoded" } ] },
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            { "name": "To", "value": "={{ $json.twilio_form.To }}" },
            { "name": "From", "value": "={{ $json.twilio_form.From }}" },
            { "name": "Body", "value": "={{ $json.twilio_form.Body }}" },
            { "name": "StatusCallback", "value": "={{ $json.twilio_form.StatusCallback }}" }
          ]
        },
        "options": { "timeout": 15000 }
      },
      "id": "ws-0009",
      "name": "Twilio Send",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1860, 320],
      "credentials": { "httpBasicAuth": { "name": "Twilio Crystallux" } },
      "continueOnFail": true,
      "alwaysOutputData": true,
      "notes": "Twilio Basic Auth credential = Account SID (user) + Auth Token (password)."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/messages_sent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ lead_id: $('Build Twilio Body').item.json.ctx.lead_id, client_id: $('Build Twilio Body').item.json.ctx.client_id, channel: 'whatsapp', direction: 'outbound', content: $('Build Twilio Body').item.json.ctx.content, external_id: ($input.item.json && $input.item.json.sid) || null, status: ($input.item.json && $input.item.json.status) || 'sent', cost_cents: 1, agent_action_id: $('Build Twilio Body').item.json.ctx.agent_action_id, video_render_id: $('Build Twilio Body').item.json.ctx.video_render_id, sent_at: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "ws-0010",
      "name": "Log messages_sent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2100, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: true, channel: 'whatsapp', external_id: ($('Twilio Send').item.json && $('Twilio Send').item.json.sid) || null }) }}",
        "options": { "responseCode": 200 }
      },
      "id": "ws-0011",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2340, 320]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'no_phone_or_unauthorized' }) }}",
        "options": { "responseCode": "={{ $json._unauthorized ? 401 : 400 }}" }
      },
      "id": "ws-0012",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [880, 660]
    }
  ],
  "connections": {
    "Webhook":           { "main": [[ { "node": "Validate", "type": "main", "index": 0 } ]] },
    "Validate":          { "main": [[ { "node": "IF Authorized", "type": "main", "index": 0 } ]] },
    "IF Authorized":     { "main": [[ { "node": "Fetch Lead Phone", "type": "main", "index": 0 }, { "node": "Fetch WA Config", "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ]] },
    "Fetch Lead Phone":  { "main": [[ { "node": "Merge Branches", "type": "main", "index": 0 } ]] },
    "Fetch WA Config":   { "main": [[ { "node": "Merge Branches", "type": "main", "index": 1 } ]] },
    "Merge Branches":    { "main": [[ { "node": "Build Twilio Body", "type": "main", "index": 0 } ]] },
    "Build Twilio Body": { "main": [[ { "node": "IF No Phone", "type": "main", "index": 0 } ]] },
    "IF No Phone":       { "main": [[ { "node": "Respond 4xx", "type": "main", "index": 0 } ], [ { "node": "Twilio Send", "type": "main", "index": 0 } ]] },
    "Twilio Send":       { "main": [[ { "node": "Log messages_sent", "type": "main", "index": 0 } ]] },
    "Log messages_sent": { "main": [[ { "node": "Respond OK", "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
