{
  "id": "clxContentScriptWriterV1",
  "name": "CLX - Content Script Writer v1",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "api/content/script-write", "responseMode": "responseNode", "options": {} },
      "id": "csw-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400],
      "webhookId": "clx-content-script-writer-001",
      "notes": "DEACTIVATED. Reads content_topic + client preferences, calls Claude to write a full video script, inserts into content_videos."
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401, error: 'Missing session token' } };\nif (!body.content_topic_id) return { json: { _empty: true, status: 400, error: 'content_topic_id required' } };\nreturn { json: { token, content_topic_id: body.content_topic_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "csw-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._unauthorized }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } },
      "id": "csw-0003", "name": "IF Bad Auth", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [640, 400]
    },
    {
      "parameters": { "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth", "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] }, "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }", "options": {} },
      "id": "csw-0004", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [880, 400],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && (rows.user_id || rows.id) ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nconst allowed = ['admin','supervisor','mga_principal','advisor','sub_agent'];\nif (allowed.indexOf(row.user_role) === -1) return { json: { _unauthorized: true, status: 403, error: 'Insufficient role' } };\nreturn { json: { _ok: true, content_topic_id: $('Extract').first().json.content_topic_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "csw-0005", "name": "Check Role", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1120, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } },
      "id": "csw-0006", "name": "IF OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1360, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/content_topics?id=eq.{{ $json.content_topic_id }}&select=*&limit=1",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "csw-0007", "name": "Fetch Topic", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1600, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst t = Array.isArray(rows) ? rows[0] : rows;\nif (!t) return { json: { _not_found: true } };\nconst systemPrompt = 'Write a 60-90 second educational video script for the topic below.\\n\\nVertical: ' + (t.vertical || 'general') + '\\nTitle: ' + t.topic_title + '\\nDescription: ' + (t.topic_description || '') + '\\n\\nOutput strictly JSON: { \"script\": <full script text>, \"hook\": <first 8 seconds>, \"value\": <middle teaching block>, \"call_to_action\": <closing>, \"estimated_duration_seconds\": <integer 60-90>, \"persona_id\": <one of: trusted-expert, friendly-coach, results-driven, warm-advisor>, \"voice_tone\": <freeform, eg \"calm-authoritative\"> }\\n\\nRules:\\n- Educational, not pushy.\\n- One key idea per video. No multi-product cramming.\\n- Conversational, plain language, no jargon.\\n- Pick persona matching the topic mood.';\nreturn { json: { topic: t, claude_payload: { model: 'claude-sonnet-4-5-20250929', max_tokens: 1500, temperature: 0.4, system: systemPrompt, messages: [ { role: 'user', content: 'Write the script.' } ] } } };",
        "mode": "runOnceForEachItem"
      },
      "id": "csw-0008", "name": "Build Prompt", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1840, 320]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._not_found }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } },
      "id": "csw-0009", "name": "IF Not Found", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [2080, 320]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Content-Type", "value": "application/json" },
          { "name": "anthropic-version", "value": "2023-06-01" },
          { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" }
        ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.claude_payload) }}",
        "options": { "timeout": 60000 }
      },
      "id": "csw-0010", "name": "Claude Write", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [2320, 240],
      "continueOnFail": true, "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const topic = $('Build Prompt').first().json.topic;\nconst resp = $input.item.json || {};\nlet text = '';\ntry { text = (resp.content && resp.content[0] && resp.content[0].text) || ''; } catch (e) {}\nlet parsed = null;\ntry { parsed = JSON.parse(String(text).replace(/```json|```/g, '').trim()); } catch (e) {}\nif (!parsed || !parsed.script) return { json: { _failed: true, error: 'Script generation failed' } };\nconst row = { content_topic_id: topic.id, client_id: topic.client_id || null, vertical: topic.vertical, persona_id: parsed.persona_id || 'trusted-expert', script: parsed.script, status: 'draft', duration_seconds: parseInt(parsed.estimated_duration_seconds) || 75 };\nreturn { json: { row, parsed } };",
        "mode": "runOnceForEachItem"
      },
      "id": "csw-0011", "name": "Build Row", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2560, 240]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/content_videos",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=representation" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.row) }}",
        "options": {}
      },
      "id": "csw-0012", "name": "Insert Video", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [2800, 240],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : rows;\nreturn { json: { ok: true, content_video: row } };",
        "mode": "runOnceForEachItem"
      },
      "id": "csw-0013", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [3040, 240]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "csw-0014", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [3280, 240] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || ($json._not_found ? 'Topic not found' : 'Unauthorized') }) }}", "options": { "responseCode": "={{ $json._not_found ? 404 : ($json.status || 401) }}" } }, "id": "csw-0015", "name": "Respond 4xx", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1360, 580] }
  ],
  "connections": {
    "Webhook":         { "main": [[ { "node": "Extract",          "type": "main", "index": 0 } ]] },
    "Extract":         { "main": [[ { "node": "IF Bad Auth",      "type": "main", "index": 0 } ]] },
    "IF Bad Auth":     { "main": [ [ { "node": "Respond 4xx",    "type": "main", "index": 0 } ], [ { "node": "Validate Session", "type": "main", "index": 0 } ] ] },
    "Validate Session":{ "main": [[ { "node": "Check Role",      "type": "main", "index": 0 } ]] },
    "Check Role":      { "main": [[ { "node": "IF OK",           "type": "main", "index": 0 } ]] },
    "IF OK":           { "main": [ [ { "node": "Fetch Topic",   "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ] ] },
    "Fetch Topic":     { "main": [[ { "node": "Build Prompt",    "type": "main", "index": 0 } ]] },
    "Build Prompt":    { "main": [[ { "node": "IF Not Found",    "type": "main", "index": 0 } ]] },
    "IF Not Found":    { "main": [ [ { "node": "Respond 4xx",   "type": "main", "index": 0 } ], [ { "node": "Claude Write", "type": "main", "index": 0 } ] ] },
    "Claude Write":    { "main": [[ { "node": "Build Row",       "type": "main", "index": 0 } ]] },
    "Build Row":       { "main": [[ { "node": "Insert Video",    "type": "main", "index": 0 } ]] },
    "Insert Video":    { "main": [[ { "node": "Shape Response",  "type": "main", "index": 0 } ]] },
    "Shape Response":  { "main": [[ { "node": "Respond OK",      "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
