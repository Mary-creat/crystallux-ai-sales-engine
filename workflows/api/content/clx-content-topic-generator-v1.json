{
  "id": "clxContentTopicGeneratorV1",
  "name": "CLX - Content Topic Generator v1",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [ { "field": "cronExpression", "expression": "0 6 * * *" } ] } },
      "id": "ctg-0001", "name": "Schedule 06:00 Daily", "type": "n8n-nodes-base.scheduleTrigger", "typeVersion": 1.2, "position": [200, 200]
    },
    {
      "parameters": { "httpMethod": "POST", "path": "api/content/topic-generate", "responseMode": "responseNode", "options": {} },
      "id": "ctg-0002", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400],
      "webhookId": "clx-content-topic-generator-001",
      "notes": "DEACTIVATED. Reads behavioral_signals + market_intelligence trends for each client, calls Claude to propose 5-10 topics, inserts into content_topics."
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/clients?active=eq.true&select=id,client_name,industry,niche_name&limit=200",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ctg-0003", "name": "Fetch Active Clients", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [480, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($input.item.json) ? $input.item.json : [];\nreturn rows.map(function (c) { return { json: { client: c } }; });",
        "mode": "runOnceForAllItems"
      },
      "id": "ctg-0004", "name": "Fan Out Clients", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [720, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/behavioral_signals?client_id=eq.{{ $json.client.id }}&select=signal_type,signal_category,signal_data,detected_at&order=detected_at.desc&limit=30",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": { "continueOnFail": true }
      },
      "id": "ctg-0005", "name": "Fetch Signals", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [960, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const client = $('Fan Out Clients').itemMatching($itemIndex).json.client;\nconst signals = Array.isArray($input.item.json) ? $input.item.json : [];\nconst vertical = client.industry || client.niche_name || 'general';\nconst systemPrompt = 'You are the Crystallux content topic generator. Propose 5-10 video topics relevant to this client\\'s audience.\\n\\nVertical: ' + vertical + '\\nClient: ' + (client.client_name || 'Unknown') + '\\nRecent behavioral signals: ' + JSON.stringify(signals.slice(0, 15)) + '\\n\\nOutput strictly JSON: { \"topics\": [ { \"topic_title\": <short title, 60 chars max>, \"topic_description\": <2-3 sentences>, \"priority_score\": <0-100>, \"target_audience\": <freeform> } ] }\\n\\nRules:\\n- Topics should be educational + valuable to the audience, not sales pitches.\\n- Tie to signals where possible (eg, market trends, life events common in this audience).\\n- Vary topic types: tips, case studies, myth-busting, news, how-tos.\\n- Use language appropriate to the vertical.';\nreturn { json: { client_id: client.id, vertical: vertical, claude_payload: { model: 'claude-sonnet-4-5-20250929', max_tokens: 1500, temperature: 0.5, system: systemPrompt, messages: [ { role: 'user', content: 'Propose 5-10 topics now.' } ] } } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ctg-0006", "name": "Build Prompt", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1200, 300]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Content-Type", "value": "application/json" },
          { "name": "anthropic-version", "value": "2023-06-01" },
          { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" }
        ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.claude_payload) }}",
        "options": { "timeout": 45000 }
      },
      "id": "ctg-0007", "name": "Claude Propose", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1440, 300],
      "continueOnFail": true, "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Build Prompt').itemMatching($itemIndex).json;\nconst resp = $input.item.json || {};\nlet text = '';\ntry { text = (resp.content && resp.content[0] && resp.content[0].text) || ''; } catch (e) {}\nlet parsed = null;\ntry { parsed = JSON.parse(String(text).replace(/```json|```/g, '').trim()); } catch (e) {}\nconst topics = (parsed && Array.isArray(parsed.topics)) ? parsed.topics : [];\nif (topics.length === 0) return [{ json: { _skip: true } }];\nreturn topics.map(function (t) { return { json: { row: { vertical: ctx.vertical, topic_title: String(t.topic_title || '').slice(0, 200), topic_description: t.topic_description || null, generated_by: 'ai', status: 'proposed', priority_score: Math.min(Math.max(parseInt(t.priority_score) || 50, 0), 100) } } }; });",
        "mode": "runOnceForAllItems"
      },
      "id": "ctg-0008", "name": "Build Rows", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1680, 300]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/content_topics",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=minimal" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.row) }}",
        "options": { "continueOnFail": true }
      },
      "id": "ctg-0009", "name": "Insert Topic", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1920, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const inserted = $('Build Rows').all().filter(function (i) { return !i.json._skip; }).length;\nreturn { json: { ok: true, topics_generated: inserted } };",
        "mode": "runOnceForAllItems"
      },
      "id": "ctg-0010", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2160, 300]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "ctg-0011", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2400, 300] }
  ],
  "connections": {
    "Schedule 06:00 Daily": { "main": [[ { "node": "Fetch Active Clients", "type": "main", "index": 0 } ]] },
    "Webhook":              { "main": [[ { "node": "Fetch Active Clients", "type": "main", "index": 0 } ]] },
    "Fetch Active Clients": { "main": [[ { "node": "Fan Out Clients",      "type": "main", "index": 0 } ]] },
    "Fan Out Clients":      { "main": [[ { "node": "Fetch Signals",        "type": "main", "index": 0 } ]] },
    "Fetch Signals":        { "main": [[ { "node": "Build Prompt",         "type": "main", "index": 0 } ]] },
    "Build Prompt":         { "main": [[ { "node": "Claude Propose",       "type": "main", "index": 0 } ]] },
    "Claude Propose":       { "main": [[ { "node": "Build Rows",           "type": "main", "index": 0 } ]] },
    "Build Rows":           { "main": [[ { "node": "Insert Topic",         "type": "main", "index": 0 } ]] },
    "Insert Topic":         { "main": [[ { "node": "Shape Response",       "type": "main", "index": 0 } ]] },
    "Shape Response":       { "main": [[ { "node": "Respond OK",           "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
