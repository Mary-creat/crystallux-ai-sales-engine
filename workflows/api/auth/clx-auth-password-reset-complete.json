{
  "name": "CLX - Auth Password Reset Complete v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "auth/password-reset-complete",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "auth-prc-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 300],
      "webhookId": "clx-auth-password-reset-complete-001"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || {};\nconst token = String(body.token || '').trim();\nconst password = String(body.password || '');\nif (token.length < 16) return { json: { ok: false, status: 400, error: 'Missing token' } };\nif (password.length < 12) return { json: { ok: false, status: 400, error: 'Password must be at least 12 characters' } };\nreturn { json: { token, password } };",
        "mode": "runOnceForEachItem"
      },
      "id": "auth-prc-0002",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/auth_password_resets?token=eq.' + encodeURIComponent($json.token) + '&select=id,user_id,expires_at,used_at&limit=1' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "auth-prc-0003",
      "name": "Lookup Reset Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json;\n// Defensive: array OR auto-unwrapped single object. See clx-auth-login note.\nconst row = Array.isArray(raw) ? (raw[0] || null) : (raw && raw.id ? raw : null);\nconst payload = $('Validate Input').item.json;\nif (!row) return { json: { ok: false, status: 401, error: 'Reset link invalid' } };\nif (row.used_at) return { json: { ok: false, status: 401, error: 'Reset link already used' } };\nif (new Date(row.expires_at).getTime() <= Date.now()) return { json: { ok: false, status: 401, error: 'Reset link expired' } };\n\nlet bcrypt;\ntry { bcrypt = require('bcryptjs'); }\ncatch (e) { return { json: { ok: false, status: 500, error: 'Server bcrypt unavailable. Set NODE_FUNCTION_ALLOW_EXTERNAL=bcryptjs.' } }; }\nconst hash = await bcrypt.hash(payload.password, 12);\nreturn { json: { ok: true, reset_id: row.id, user_id: row.user_id, password_hash: hash } };",
        "mode": "runOnceForEachItem"
      },
      "id": "auth-prc-0004",
      "name": "Hash New Password",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [
            { "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "auth-prc-0005",
      "name": "IF Hash OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/auth_users?id=eq.' + encodeURIComponent($json.user_id) }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"password_hash\": \"{{ $json.password_hash }}\", \"failed_login_attempts\": 0, \"locked_until\": null }",
        "options": {}
      },
      "id": "auth-prc-0006",
      "name": "Update Password",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/auth_password_resets?id=eq.' + encodeURIComponent($('Hash New Password').item.json.reset_id) }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"used_at\": \"{{ new Date().toISOString() }}\" }",
        "options": {}
      },
      "id": "auth-prc-0007",
      "name": "Mark Reset Used",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1580, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/auth_sessions?user_id=eq.' + encodeURIComponent($('Hash New Password').item.json.user_id) + '&revoked_at=is.null' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"revoked_at\": \"{{ new Date().toISOString() }}\" }",
        "options": {}
      },
      "id": "auth-prc-0008",
      "name": "Revoke All Sessions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1800, 220],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } },
      "continueOnFail": true
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: true, message: 'Password updated. Please log in.' } }}",
        "options": { "responseCode": 200 }
      },
      "id": "auth-prc-0009",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2020, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: false, error: $json.error || 'Reset failed' } }}",
        "options": { "responseCode": "={{ $json.status || 400 }}" }
      },
      "id": "auth-prc-0010",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1340, 420]
    }
  ],
  "connections": {
    "Webhook":             { "main": [[ { "node": "Validate Input",     "type": "main", "index": 0 } ]] },
    "Validate Input":      { "main": [[ { "node": "Lookup Reset Token", "type": "main", "index": 0 } ]] },
    "Lookup Reset Token":  { "main": [[ { "node": "Hash New Password",  "type": "main", "index": 0 } ]] },
    "Hash New Password":   { "main": [[ { "node": "IF Hash OK",         "type": "main", "index": 0 } ]] },
    "IF Hash OK":          { "main": [
                                      [ { "node": "Update Password",    "type": "main", "index": 0 } ],
                                      [ { "node": "Respond 4xx",        "type": "main", "index": 0 } ]
                                    ] },
    "Update Password":     { "main": [[ { "node": "Mark Reset Used",    "type": "main", "index": 0 } ]] },
    "Mark Reset Used":     { "main": [[ { "node": "Revoke All Sessions","type": "main", "index": 0 } ]] },
    "Revoke All Sessions": { "main": [[ { "node": "Respond OK",         "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
