{
  "name": "CLX - Training Topic List v1",
  "nodes": [
    { "parameters": { "httpMethod": "POST", "path": "api/training/topics", "responseMode": "responseNode", "options": {} }, "id": "ttl-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400], "webhookId": "clx-training-topic-list-001", "notes": "DEACTIVATED. Session-token. Returns training_topics filtered by optional vertical_id + the requesting user's training_sessions for completion status." },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401 } };\nreturn { json: { token, vertical_id: body.vertical_id || null } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ttl-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._unauthorized }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } }, "id": "ttl-0003", "name": "IF Bad", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [640, 400] },
    { "parameters": { "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth", "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] }, "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }", "options": {} }, "id": "ttl-0004", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [880, 400], "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } } },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401 } };\nreturn { json: { _ok: true, user_id: row.user_id, vertical_id: $('Extract').first().json.vertical_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "ttl-0005", "name": "Check Session", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1120, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } }, "id": "ttl-0006", "name": "IF OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1360, 400] },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/training_topics?is_active=eq.true' + ($json.vertical_id ? '&or=(vertical_id.is.null,vertical_id.eq.' + $json.vertical_id + ')' : '&vertical_id=is.null') + '&order=topic_category.asc,difficulty_level.asc&select=*' }}",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "ttl-0007", "name": "Fetch Topics", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1600, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/training_sessions?user_id=eq.{{ $('Check Session').first().json.user_id }}&select=topic_id,completed,user_rating,competency_score,completed_at",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": { "continueOnFail": true }
      },
      "id": "ttl-0008", "name": "Fetch Sessions", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1600, 480],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    { "parameters": { "type": "combineByPosition", "options": {} }, "id": "ttl-0009", "name": "Merge", "type": "n8n-nodes-base.merge", "typeVersion": 3, "position": [1840, 400] },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) { try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; } };\nconst topics = allOf('Fetch Topics');\nconst sessions = allOf('Fetch Sessions');\nconst byTopic = {};\nsessions.forEach(function (s) { if (!s.topic_id) return; const t = byTopic[s.topic_id] || { sessions: 0, completed: false, best_score: 0 }; t.sessions += 1; if (s.completed) t.completed = true; if ((s.competency_score || 0) > t.best_score) t.best_score = s.competency_score; byTopic[s.topic_id] = t; });\nconst enriched = topics.map(function (t) { const st = byTopic[t.id] || { sessions: 0, completed: false, best_score: 0 }; return Object.assign({}, t, { sessions_count: st.sessions, completed: st.completed, best_score: st.best_score }); });\nreturn { json: { ok: true, topics: enriched } };",
        "mode": "runOnceForAllItems"
      },
      "id": "ttl-0010", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2080, 400]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "ttl-0011", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2320, 400] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}", "options": { "responseCode": "={{ $json.status || 401 }}" } }, "id": "ttl-0012", "name": "Respond 4xx", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [880, 200] }
  ],
  "connections": {
    "Webhook":         { "main": [[ { "node": "Extract", "type": "main", "index": 0 } ]] },
    "Extract":         { "main": [[ { "node": "IF Bad",  "type": "main", "index": 0 } ]] },
