{
  "name": "CLX - Production Report Fetch v1",
  "nodes": [
    { "parameters": { "httpMethod": "POST", "path": "api/reports/fetch", "responseMode": "responseNode", "options": {} }, "id": "prf-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400], "webhookId": "clx-production-report-fetch-001", "notes": "DEACTIVATED. Session-token. Returns a specific report scoped to the requester's user_id. Marks viewed_at on first read." },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401 } };\nif (!body.report_id) return { json: { _empty: true, status: 400, error: 'report_id required' } };\nreturn { json: { token, report_id: body.report_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "prf-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._unauthorized || $json._empty }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } }, "id": "prf-0003", "name": "IF Bad", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [640, 400] },
    { "parameters": { "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth", "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] }, "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }", "options": {} }, "id": "prf-0004", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [880, 400], "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } } },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401 } };\nreturn { json: { _ok: true, user_id: row.user_id, report_id: $('Extract').first().json.report_id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "prf-0005", "name": "Check Session", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1120, 400]
    },
    { "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } }, "id": "prf-0006", "name": "IF OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1360, 400] },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/production_reports?id=eq.{{ $json.report_id }}&recipient_id=eq.{{ $json.user_id }}&select=*&limit=1",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Accept", "value": "application/json" } ] },
        "options": {}
      },
      "id": "prf-0007", "name": "Fetch Report", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1600, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/production_reports?id=eq.{{ (Array.isArray($json) ? $json[0] : $json).id }}&viewed_at=is.null",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=minimal" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"viewed_at\": \"{{ new Date().toISOString() }}\", \"status\": \"viewed\" }",
        "options": { "continueOnFail": true }
      },
      "id": "prf-0008", "name": "Mark Viewed", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1840, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $('Fetch Report').first().json;\nconst r = Array.isArray(rows) ? rows[0] : rows;\nif (!r) return { json: { ok: false, status: 404, error: 'Report not found or not yours' } };\nreturn { json: { ok: true, report: r } };",
        "mode": "runOnceForAllItems"
      },
      "id": "prf-0009", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [2080, 320]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "prf-0010", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2320, 320] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}", "options": { "responseCode": "={{ $json.status || 401 }}" } }, "id": "prf-0011", "name": "Respond 4xx", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [880, 200] }
  ],
  "connections": {
    "Webhook":         { "main": [[ { "node": "Extract", "type": "main", "index": 0 } ]] },
    "Extract":         { "main": [[ { "node": "IF Bad",  "type": "main", "index": 0 } ]] },
    "IF Bad":          { "main": [ [ { "node": "Respond 4xx", "type": "main", "index": 0 } ], [ { "node": "Validate Session", "type": "main", "index": 0 } ] ] },
    "Validate Session":{ "main": [[ { "node": "Check Session", "type": "main", "index": 0 } ]] },
    "Check Session":   { "main": [[ { "node": "IF OK", "type": "main", "index": 0 } ]] },
    "IF OK":           { "main": [ [ { "node": "Fetch Report", "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ] ] },
    "Fetch Report":    { "main": [[ { "node": "Mark Viewed", "type": "main", "index": 0 } ]] },
    "Mark Viewed":     { "main": [[ { "node": "Shape Response", "type": "main", "index": 0 } ]] },
    "Shape Response":  { "main": [[ { "node": "Respond OK", "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
