    {
      "parameters": {
        "jsCode": "const allOf = function (name) { try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; } };\nconst advisors = allOf('Fetch Advisors');\nconst policies = allOf('Fetch Policies');\nconst commissions = allOf('Fetch Commissions');\nconst reviews = allOf('Fetch Reviews');\nconst now = new Date();\nconst monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();\nconst yearStart = new Date(now.getFullYear(), 0, 1).toISOString();\nlet mtdMga = 0, ytdMga = 0, mtdAdvisor = 0, ytdAdvisor = 0;\nfor (const c of commissions) {\n  const m = parseInt(c.mga_commission) || 0;\n  const a = parseInt(c.advisor_commission) || 0;\n  if (c.created_at >= yearStart) { ytdMga += m; ytdAdvisor += a; }\n  if (c.created_at >= monthStart) { mtdMga += m; mtdAdvisor += a; }\n}\nconst totalReviews = reviews.length;\nconst completedReviews = reviews.filter(function (r) { return r.status === 'completed'; });\nconst overdueReviews = reviews.filter(function (r) { return r.status === 'overdue' || r.status === 'escalated'; });\nconst completedOnTime = completedReviews.filter(function (r) { return r.conducted_date && r.due_date && r.conducted_date <= r.due_date; }).length;\nconst onTimePct = completedReviews.length > 0 ? Math.round(completedOnTime / completedReviews.length * 100) : 0;\nconst overduePct = totalReviews > 0 ? Math.round(overdueReviews.length / totalReviews * 100) : 0;\nconst signalReviews = reviews.filter(function (r) { return r.trigger_source === 'behavioral_signal'; });\nconst signalEngaged = signalReviews.filter(function (r) { return r.video_engagement_status === 'viewed' || r.video_engagement_status === 'replied' || r.video_engagement_status === 'meeting_booked'; }).length;\nconst signalEffectivenessPct = signalReviews.length > 0 ? Math.round(signalEngaged / signalReviews.length * 100) : 0;\nreturn { json: { ok: true, vertical_id: 'insurance', advisors: { active_count: advisors.length }, policies: { in_force_count: policies.length }, commissions: { mtd_mga_cents: mtdMga, ytd_mga_cents: ytdMga, mtd_advisor_cents: mtdAdvisor, ytd_advisor_cents: ytdAdvisor }, reviews: { total: totalReviews, completed: completedReviews.length, overdue: overdueReviews.length, on_time_pct: onTimePct, overdue_pct: overduePct }, behavioral_intelligence: { triggered_reviews: signalReviews.length, engaged: signalEngaged, effectiveness_pct: signalEffectivenessPct } } };",
        "mode": "runOnceForAllItems"
      },
