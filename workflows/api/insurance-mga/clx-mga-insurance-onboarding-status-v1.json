        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) { try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; } };\nconst curriculum = allOf('Fetch Curriculum');\nconst progress = allOf('Fetch Progress');\nconst progressByCurriculum = {};\nprogress.forEach(function (p) { progressByCurriculum[p.curriculum_id] = p; });\nconst items = curriculum.map(function (c) { const p = progressByCurriculum[c.id] || null; return Object.assign({}, c, { progress: p, status: p ? p.status : 'pending' }); });\nconst completed = items.filter(function (i) { return i.status === 'completed'; }).length;\nconst inProgress = items.filter(function (i) { return i.status === 'in_progress'; }).length;\nconst currentDay = items.find(function (i) { return i.status === 'in_progress' || i.status === 'pending'; });\nreturn { json: { ok: true, vertical_id: 'insurance', total_days: items.length, completed_days: completed, in_progress_days: inProgress, current_day: currentDay ? currentDay.day_number : items.length + 1, days: items } };",
        "mode": "runOnceForAllItems"
      },
