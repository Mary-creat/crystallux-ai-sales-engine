{
  "name": "CLX - MGA Insurance Carrier Create v1",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "mga/insurance/carrier-create", "responseMode": "responseNode", "options": {} },
      "id": "cc-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 400],
      "webhookId": "clx-mga-insurance-carrier-create-001",
      "notes": "DEACTIVATED. mga_principal/admin only. Inserts an insurance_carriers row (vertical_id='insurance')."
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401, error: 'Missing session token' } };\nif (!body.carrier_name || !body.carrier_type) return { json: { _empty: true, status: 400, error: 'carrier_name and carrier_type required' } };\nreturn { json: { token, body } };",
        "mode": "runOnceForEachItem"
      },
      "id": "cc-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 400]
    },
    {
      "parameters": { "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth", "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] }, "sendBody": true, "specifyBody": "json", "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }", "options": {} },
      "id": "cc-0003", "name": "Validate Session", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [640, 400],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nif (row.user_role !== 'mga_principal' && row.user_role !== 'admin') return { json: { _unauthorized: true, status: 403, error: 'mga_principal role required' } };\nconst b = $('Extract').item.json.body;\nconst payload = { vertical_id: 'insurance', carrier_name: b.carrier_name, carrier_code: b.carrier_code || null, carrier_type: b.carrier_type, province_licensed: Array.isArray(b.province_licensed) ? b.province_licensed : [], ai_compliance_ready: !!b.ai_compliance_ready, digital_quote_ready: !!b.digital_quote_ready, api_endpoint: b.api_endpoint || null, api_auth_type: b.api_auth_type || null, contact_email: b.contact_email || null, contact_phone: b.contact_phone || null, notes: b.notes || null };\nreturn { json: { _ok: true, mga_principal_id: row.id || row.user_id, payload } };",
        "mode": "runOnceForEachItem"
      },
      "id": "cc-0004", "name": "Check Role", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [880, 400]
    },
    {
      "parameters": { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "id": "c1", "leftValue": "={{ $json._ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ], "combinator": "and" } },
      "id": "cc-0005", "name": "IF OK", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1120, 400]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/insurance_carriers?on_conflict=vertical_id,carrier_name", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "resolution=merge-duplicates,return=representation" } ] },
        "sendBody": true, "specifyBody": "json", "jsonBody": "={{ JSON.stringify($json.payload) }}", "options": {}
      },
      "id": "cc-0006", "name": "Upsert Carrier", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1360, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "method": "POST", "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/regulatory_audit_log", "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=minimal" } ] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"vertical_id\": \"insurance\", \"event_type\": \"carrier_created\", \"event_data\": {{ JSON.stringify({ carrier_name: $('Check Role').first().json.payload.carrier_name, carrier_type: $('Check Role').first().json.payload.carrier_type }) }}, \"actor_user_id\": \"{{ $('Check Role').first().json.mga_principal_id }}\" }",
        "options": { "continueOnFail": true }
      },
      "id": "cc-0007", "name": "Audit Log", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1600, 320],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "const rows = $('Upsert Carrier').first().json;\nconst row  = Array.isArray(rows) ? (rows[0] || null) : rows;\nreturn { json: { ok: true, carrier: row } };",
        "mode": "runOnceForAllItems"
      },
      "id": "cc-0008", "name": "Shape Response", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1840, 320]
    },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}", "options": { "responseCode": 200 } }, "id": "cc-0009", "name": "Respond OK", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [2080, 320] },
    { "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}", "options": { "responseCode": "={{ $json.status || 401 }}" } }, "id": "cc-0010", "name": "Respond 4xx", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1120, 580] }
  ],
  "connections": {
    "Webhook":         { "main": [[ { "node": "Extract",          "type": "main", "index": 0 } ]] },
    "Extract":         { "main": [[ { "node": "Validate Session", "type": "main", "index": 0 } ]] },
    "Validate Session":{ "main": [[ { "node": "Check Role",       "type": "main", "index": 0 } ]] },
    "Check Role":      { "main": [[ { "node": "IF OK",            "type": "main", "index": 0 } ]] },
    "IF OK":           { "main": [ [ { "node": "Upsert Carrier", "type": "main", "index": 0 } ], [ { "node": "Respond 4xx", "type": "main", "index": 0 } ] ] },
    "Upsert Carrier":  { "main": [[ { "node": "Audit Log",        "type": "main", "index": 0 } ]] },
    "Audit Log":       { "main": [[ { "node": "Shape Response",   "type": "main", "index": 0 } ]] },
    "Shape Response":  { "main": [[ { "node": "Respond OK",       "type": "main", "index": 0 } ]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
