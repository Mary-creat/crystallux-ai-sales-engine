{
  "id": "clxMgaInsuranceInsurerSessionValidateV1",
  "name": "CLX - MGA Insurance Insurer Session Validate v1",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mga/insurance/insurer-session-validate",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "isv-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        200,
        400
      ],
      "webhookId": "clx-mga-insurance-insurer-session-validate-001",
      "notes": "DEACTIVATED. Internal — called by every insurer-facing webhook. Validates session token belongs to an insurer_user, returns account + permissions + access_level. 4-hour session expiry enforced."
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || {};\nconst token = body.token || '';\nif (!token) return { json: { _unauthorized: true, status: 401, error: 'Missing token' } };\nreturn { json: { token } };",
        "mode": "runOnceForEachItem"
      },
      "id": "isv-0002",
      "name": "Extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json._unauthorized }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "isv-0003",
      "name": "IF Bad",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        640,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/rpc/validate_session",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"p_token\": \"{{ $json.token }}\" }",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "isv-0004",
      "name": "Validate Session",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        400
      ],
      "credentials": {
        "httpCustomAuth": {
          "name": "Supabase Crystallux Custom"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.user_id || rows.id) ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nif (row.user_role !== 'insurer_user' && row.user_role !== 'admin') return { json: { _unauthorized: true, status: 403, error: 'Not an insurer session' } };\nif (row.created_at) { const ageMs = Date.now() - new Date(row.created_at).getTime(); if (ageMs > 4 * 3600 * 1000) return { json: { _unauthorized: true, status: 401, error: 'Insurer session expired (4-hour limit)' } }; }\nreturn { json: { _ok: true, user_id: row.user_id, email: row.email, user_role: row.user_role } };",
        "mode": "runOnceForEachItem"
      },
      "id": "isv-0005",
      "name": "Check Role",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        400
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json._ok }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "isv-0006",
      "name": "IF OK",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1360,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/insurer_users?user_id=eq.{{ $json.user_id }}&is_active=eq.true&select=*,insurer_accounts(*)&limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "id": "isv-0007",
      "name": "Fetch Insurer Link",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1600,
        320
      ],
      "credentials": {
        "httpCustomAuth": {
          "name": "Supabase Crystallux Custom"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst link = Array.isArray(rows) ? rows[0] : rows;\nconst session = $('Check Role').first().json;\nif (!link) return { json: { ok: false, status: 403, error: 'No active insurer_users row for this user' } };\nconst account = link.insurer_accounts || null;\nif (!account || account.account_status !== 'active') return { json: { ok: false, status: 403, error: 'Insurer account not active' } };\nreturn { json: { ok: true, user_id: session.user_id, email: session.email, role_at_insurer: link.role_at_insurer, permissions: link.permissions || {}, insurer_account: { id: account.id, company_name: account.company_name, carrier_id: account.carrier_id, access_level: account.access_level, data_sharing_consent: account.data_sharing_consent || {} } } };",
        "mode": "runOnceForEachItem"
      },
      "id": "isv-0008",
      "name": "Shape Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1840,
        320
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "isv-0009",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        2080,
        320
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Unauthorized' }) }}",
        "options": {
          "responseCode": "={{ $json.status || 401 }}"
        }
      },
      "id": "isv-0010",
      "name": "Respond 4xx",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        880,
        200
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
