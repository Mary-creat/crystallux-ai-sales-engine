      },
      "id": "cl-0008",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1840,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const allOf = function (name) {\n  try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; }\n};\nconst carriers = allOf('Fetch Carriers');\nconst products = allOf('Fetch Products');\nconst byCarrier = {};\ncarriers.forEach(function (c) { byCarrier[c.id] = Object.assign({}, c, { products: [] }); });\nproducts.forEach(function (p) { if (byCarrier[p.carrier_id]) byCarrier[p.carrier_id].products.push(p); });\nreturn { json: { ok: true, carriers: Object.keys(byCarrier).map(function (k) { return byCarrier[k]; }), products_total: products.length } };",
        "mode": "runOnceForAllItems"
      },
