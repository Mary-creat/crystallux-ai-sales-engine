    },
    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? (rows[0] || null) : (rows && (rows.user_id || rows.id) ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nconst allowed = ['mga_principal','compliance_officer','admin'];\nif (allowed.indexOf(row.user_role) < 0) return { json: { _unauthorized: true, status: 403, error: 'mga_principal/compliance_officer role required' } };\nreturn { json: { _ok: true, principal_id: row.id || row.user_id, user_role: row.user_role } };",
        "mode": "runOnceForEachItem"
      },
