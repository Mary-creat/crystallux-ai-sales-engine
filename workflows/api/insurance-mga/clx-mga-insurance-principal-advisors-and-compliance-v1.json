    {
      "parameters": {
        "jsCode": "const allOf = function (name) { try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; } };\nconst advisors = allOf('Fetch Advisors');\nconst licenses = allOf('Fetch Licenses');\nconst eo = allOf('Fetch E&O');\nconst complianceQ = allOf('Fetch Compliance Queue');\nconst complaintQ = allOf('Fetch Complaint Queue');\n// Build advisor roster with license + E&O status joined.\nconst licByAdvisor = {};\nfor (const l of licenses) { (licByAdvisor[l.advisor_id] = licByAdvisor[l.advisor_id] || []).push(l); }\nconst eoByAdvisor = {};\nfor (const e of eo) { (eoByAdvisor[e.advisor_id] = eoByAdvisor[e.advisor_id] || []).push(e); }\nconst roster = advisors.map(function (a) {\n  const lics = licByAdvisor[a.id] || [];\n  const eos = eoByAdvisor[a.id] || [];\n  const minRenewal = lics.reduce(function (acc, l) { const order = ['expired','expiring_7d','expiring_14d','expiring_30d','expiring_60d','current']; return order.indexOf(l.renewal_status) < order.indexOf(acc) ? l.renewal_status : acc; }, 'current');\n  return { advisor_id: a.id, email: a.email, full_name: a.full_name, role: a.user_role, status: a.status, license_count: lics.length, eo_count: eos.length, worst_renewal_status: minRenewal };\n});\nreturn { json: { ok: true, vertical_id: 'insurance', advisors: roster, advisor_count: roster.length, compliance_queue: complianceQ, compliance_queue_count: complianceQ.length, complaint_audit_queue: complaintQ, complaint_audit_queue_count: complaintQ.length } };",
        "mode": "runOnceForAllItems"
      },
