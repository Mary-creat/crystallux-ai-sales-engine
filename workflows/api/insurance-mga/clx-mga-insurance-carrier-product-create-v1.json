      "webhookId": "clx-mga-insurance-carrier-product-create-001",
      "notes": "DEACTIVATED. mga_principal/admin only. Inserts a carrier_products row (vertical_id='insurance')."
    },
    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body = $input.item.json.body || {};\nconst auth = headers['authorization'] || headers['Authorization'] || '';\nconst token = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401, error: 'Missing session token' } };\nif (!body.carrier_id || !body.product_name || !body.product_type) return { json: { _empty: true, status: 400, error: 'carrier_id, product_name, product_type required' } };\nreturn { json: { token, body } };",
        "mode": "runOnceForEachItem"
      },
      "id": "cpc-0002",
