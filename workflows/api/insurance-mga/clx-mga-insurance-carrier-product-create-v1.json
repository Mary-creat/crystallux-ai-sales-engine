    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nif (row.user_role !== 'mga_principal' && row.user_role !== 'admin') return { json: { _unauthorized: true, status: 403, error: 'mga_principal role required' } };\nconst b = $('Extract').item.json.body;\nconst payload = { vertical_id: 'insurance', carrier_id: b.carrier_id, product_name: b.product_name, product_type: b.product_type, product_code: b.product_code || null, min_coverage_cents: b.min_coverage_cents || null, max_coverage_cents: b.max_coverage_cents || null, base_premium_cents: b.base_premium_cents || null, premium_formula: b.premium_formula || null, underwriting_min_age: b.underwriting_min_age || null, underwriting_max_age: b.underwriting_max_age || null, underwriting_notes: b.underwriting_notes || null, commission_pct: b.commission_pct || null, commission_first_year: b.commission_first_year || null, commission_renewal: b.commission_renewal || null, ai_compliance_ready: !!b.ai_compliance_ready, features: Array.isArray(b.features) ? b.features : [], active: true };\nreturn { json: { _ok: true, payload } };",
        "mode": "runOnceForEachItem"
      },
