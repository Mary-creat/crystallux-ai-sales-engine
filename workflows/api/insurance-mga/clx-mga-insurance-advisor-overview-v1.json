    {
      "parameters": {
        "jsCode": "const allOf = function (name) { try { const items = $(name).all().map(function (i) { return i.json; }); if (items.length === 1 && Array.isArray(items[0])) return items[0]; return items; } catch (e) { return []; } };\nconst reviews = allOf('Fetch Reviews');\nconst leads = allOf('Fetch Leads');\nconst apps = allOf('Fetch Applications');\nconst licenses = allOf('Fetch Licenses');\nconst now = Date.now();\nconst todayStr = new Date(now).toISOString().slice(0,10);\nconst weekEnd = new Date(now + 7*86400000).toISOString().slice(0,10);\nconst monthEnd = new Date(now + 30*86400000).toISOString().slice(0,10);\n\nconst overdue = reviews.filter(function (r) { return r.due_date < todayStr && (r.status === 'scheduled' || r.status === 'in_progress' || r.status === 'overdue'); });\nconst dueThisWeek = reviews.filter(function (r) { return r.due_date >= todayStr && r.due_date <= weekEnd && (r.status === 'scheduled'); });\nconst upcoming30 = reviews.filter(function (r) { return r.due_date > weekEnd && r.due_date <= monthEnd && (r.status === 'scheduled'); });\nconst inProgress = reviews.filter(function (r) { return r.status === 'in_progress'; });\nconst urgent = reviews.filter(function (r) { return r.priority === 'urgent' && r.status !== 'completed' && r.status !== 'cancelled'; });\nconst videoSent = reviews.filter(function (r) { return r.video_engagement_status === 'sent'; }).length;\nconst videoViewed = reviews.filter(function (r) { return r.video_engagement_status === 'viewed' || r.video_engagement_status === 'replied' || r.video_engagement_status === 'meeting_booked'; }).length;\nconst videoBooked = reviews.filter(function (r) { return r.video_engagement_status === 'meeting_booked'; }).length;\n\nconst leadByStatus = {};\nfor (const l of leads) { const s = l.lead_status || 'unknown'; leadByStatus[s] = (leadByStatus[s] || 0) + 1; }\nconst appsByStatus = {};\nfor (const a of apps) { const s = a.submission_status || 'unknown'; appsByStatus[s] = (appsByStatus[s] || 0) + 1; }\nconst licenseAlerts = licenses.filter(function (lc) { return lc.renewal_status !== 'current'; });\n\n// Last 30 days metrics\nconst since30 = new Date(now - 30*86400000).toISOString();\nconst issuedRecent = apps.filter(function (a) { return a.issued_at && a.issued_at >= since30; }).length;\nconst reviewsCompletedRecent = reviews.filter(function (r) { return r.status === 'completed'; }).length;\n\nreturn { json: { ok: true, vertical_id: 'insurance', advisor_id: $('Check Role').item.json.advisor_id, action_required: { urgent_count: urgent.length, urgent: urgent.slice(0, 10), overdue_count: overdue.length, overdue: overdue.slice(0, 20) }, due_this_week: { count: dueThisWeek.length, list: dueThisWeek.slice(0, 20) }, upcoming_30d: { count: upcoming30.length }, in_progress: { count: inProgress.length, list: inProgress.slice(0, 10) }, pipeline: { leads: leads.length, leads_by_status: leadByStatus, applications: apps.length, applications_by_status: appsByStatus }, license_alerts: licenseAlerts, metrics_30d: { policies_issued: issuedRecent, reviews_completed: reviewsCompletedRecent, total_reviews: reviews.length }, video_engagement: { sent: videoSent, viewed_or_replied: videoViewed, meetings_booked: videoBooked, conversion_rate: videoSent > 0 ? Math.round(videoBooked / videoSent * 100) : 0 } } };",
        "mode": "runOnceForAllItems"
      },
