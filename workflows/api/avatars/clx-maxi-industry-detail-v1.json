    {
      "parameters": {
        "jsCode": "const rows = $input.item.json;\nconst row  = Array.isArray(rows) ? rows[0] : (rows && rows.id ? rows : null);\nif (!row) return { json: { _unauthorized: true, status: 401, error: 'Invalid session' } };\nif (row.user_role !== 'admin') return { json: { _unauthorized: true, status: 403, error: 'Admin role required' } };\nconst prior = $('Extract').item.json;\nreturn { json: { _ok: true, user_id: row.user_id, slug: prior.slug } };"
      },
