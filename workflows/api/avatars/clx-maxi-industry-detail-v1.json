    {
      "parameters": {
        "jsCode": "const headers = $input.item.json.headers || {};\nconst body    = $input.item.json.body || {};\nconst auth    = headers['authorization'] || headers['Authorization'] || '';\nconst token   = auth.toLowerCase().startsWith('bearer ') ? auth.slice(7).trim() : '';\nif (!token) return { json: { _unauthorized: true, status: 401, error: 'Missing session token' } };\n\nconst slug = body.industry_slug ? String(body.industry_slug).trim().toLowerCase() : '';\nif (!slug) return { json: { _unauthorized: true, status: 400, error: 'industry_slug is required' } };\n// Whitelist allowed characters (anti-injection — slug only goes into a PostgREST eq.<slug> filter, but defence-in-depth)\nif (!/^[a-z0-9_]+$/.test(slug)) return { json: { _unauthorized: true, status: 400, error: 'invalid industry_slug format' } };\n\nreturn { json: { token, slug } };"
      },
      "id": "mid-0002",
      "name": "Extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
