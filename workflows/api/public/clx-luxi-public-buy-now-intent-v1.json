{
  "id": "wfLuxiPublicBuyNowIntentV1",
  "name": "CLX - LUXI Public Buy Now Intent v1",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "public/luxi/buy-now-intent", "responseMode": "responseNode", "options": {} },
      "id": "lbi-0001", "name": "Webhook", "type": "n8n-nodes-base.webhook", "typeVersion": 1.1, "position": [200, 300],
      "webhookId": "clx-luxi-public-buy-now-intent-001",
      "notes": "DEACTIVATED. PUBLIC. Creates an auto-capture Stripe PaymentIntent for an item's Buy Now price. Body: { auction_id }. Returns { client_secret, payment_intent_id, amount_cents }. Needs STRIPE_SECRET_KEY."
    },
    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || {};\nconst id = String(body.auction_id || '').trim();\nif (!id) return { json: { ok: false, status: 400, error: 'auction_id required' } };\nreturn { json: { auction_id: id } };",
        "mode": "runOnceForEachItem"
      },
      "id": "lbi-0002", "name": "Extract", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [420, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://zqwatouqmqgkmaslydbr.supabase.co/rest/v1/auctions?id=eq.' + $json.auction_id + '&select=id,status,listing_type,buy_now_price_cents&limit=1' }}",
        "authentication": "genericCredentialType", "genericAuthType": "httpCustomAuth",
        "sendHeaders": true, "headerParameters": { "parameters": [{ "name": "Accept", "value": "application/json" }] },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "lbi-0003", "name": "Fetch Auction", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [660, 300],
      "credentials": { "httpCustomAuth": { "name": "Supabase Crystallux Custom" } }
    },
    {
      "parameters": {
        "jsCode": "let rows = $input.item.json;\nif (!Array.isArray(rows)) rows = rows && rows.id ? [rows] : [];\nif (rows.length === 0) return { json: { ok: false, status: 404, error: 'Auction not found' } };\nconst a = rows[0];\nif (a.listing_type !== 'buy_now' && a.listing_type !== 'both') return { json: { ok: false, status: 409, error: 'This item is not available for Buy Now' } };\nif (!a.buy_now_price_cents || a.buy_now_price_cents <= 0) return { json: { ok: false, status: 409, error: 'This item has no Buy Now price' } };\nif (a.status !== 'open' && a.status !== 'extended' && a.status !== 'scheduled') return { json: { ok: false, status: 409, error: 'This item is no longer available' } };\nreturn { json: { ok: true, auction_id: a.id, amount_cents: a.buy_now_price_cents } };",
        "mode": "runOnceForEachItem"
      },
      "id": "lbi-0004", "name": "Validate", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [{ "id": "c1", "leftValue": "={{ $json.ok }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }], "combinator": "and" }
      },
      "id": "lbi-0005", "name": "IF Valid", "type": "n8n-nodes-base.if", "typeVersion": 2.2, "position": [1140, 300]
    },
    {
      "parameters": {
        "method": "POST", "url": "https://api.stripe.com/v1/payment_intents",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "Authorization", "value": "={{ 'Bearer ' + $env.STRIPE_SECRET_KEY }}" },
          { "name": "Content-Type", "value": "application/x-www-form-urlencoded" }
        ] },
        "sendBody": true, "specifyBody": "string",
        "body": "={{ 'amount=' + $json.amount_cents + '&currency=cad&automatic_payment_methods[enabled]=true&metadata[auction_id]=' + $json.auction_id + '&metadata[kind]=luxi_buynow&metadata[amount_cents]=' + $json.amount_cents }}",
        "options": { "response": { "response": { "neverError": true } } }
      },
      "id": "lbi-0006", "name": "Stripe Create Intent", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1380, 220]
    },
    {
      "parameters": {
        "jsCode": "const s = $input.item.json || {};\nconst v = $('Validate').item.json;\nif (s.error) return { json: { ok: false, status: 502, error: 'Stripe: ' + (s.error.message || 'create failed') } };\nif (!s.id || !s.client_secret) return { json: { ok: false, status: 502, error: 'Stripe did not return a PaymentIntent (is STRIPE_SECRET_KEY set?)' } };\nreturn { json: { ok: true, status: 200, payment_intent_id: s.id, client_secret: s.client_secret, amount_cents: v.amount_cents } };",
        "mode": "runOnceForEachItem"
      },
      "id": "lbi-0007", "name": "Shape", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1620, 220]
    },
    {
      "parameters": {
        "respondWith": "json", "responseBody": "={{ JSON.stringify($json) }}",
        "options": { "responseCode": "={{ $json.status || 200 }}", "responseHeaders": { "entries": [
          { "name": "Access-Control-Allow-Origin", "value": "*" },
          { "name": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
          { "name": "Access-Control-Allow-Headers", "value": "Content-Type" }
        ] } }
      },
      "id": "lbi-0008", "name": "Respond", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1860, 220]
    },
    {
      "parameters": {
        "respondWith": "json", "responseBody": "={{ JSON.stringify({ ok: false, error: $json.error || 'Bad request' }) }}",
        "options": { "responseCode": "={{ $json.status || 400 }}", "responseHeaders": { "entries": [{ "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "lbi-0009", "name": "Respond Error", "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [1380, 460]
    }
  ],
  "connections": {
    "Webhook":      { "main": [[{ "node": "Extract",       "type": "main", "index": 0 }]] },
    "Extract":      { "main": [[{ "node": "Fetch Auction", "type": "main", "index": 0 }]] },
    "Fetch Auction":{ "main": [[{ "node": "Validate",      "type": "main", "index": 0 }]] },
    "Validate":     { "main": [[{ "node": "IF Valid",      "type": "main", "index": 0 }]] },
    "IF Valid": { "main": [
      [{ "node": "Stripe Create Intent", "type": "main", "index": 0 }],
      [{ "node": "Respond Error",        "type": "main", "index": 0 }]
    ] },
    "Stripe Create Intent": { "main": [[{ "node": "Shape",   "type": "main", "index": 0 }]] },
    "Shape":                { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "active": false
}
