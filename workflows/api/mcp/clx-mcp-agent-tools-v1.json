        "jsCode": "const ctx = $('Parse Request').item.json;\nconst all = $input.all();\nconst data = all.length === 1 ? (all[0].json && (all[0].json.result || all[0].json)) : all.map(function(i){return i.json;});\nreturn { json: { success: true, tool: ctx.tool_name, data: data, timestamp: new Date().toISOString() } };",
        "mode": "runOnceForAllItems"
