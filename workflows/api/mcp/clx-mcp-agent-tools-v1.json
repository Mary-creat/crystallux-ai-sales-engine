      },
      "id": "mat-0001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [200, 500],
      "webhookId": "clx-mcp-agent-tools-001",
      "notes": "DEACTIVATED. Internal-call (INTERNAL_EMAIL_SECRET — system-level, not session). Write-tool MCP gateway — extends the existing read-only clx-mcp-tool-gateway with the action tools the AI Agent needs. Each tool wraps an underlying workflow. Logs every invocation to mcp_tool_calls. Claude (in C1 decision engine, future) can call this with { tool_name, tool_input } to take real actions: place_outbound_call, send_whatsapp, send_sms, send_email, generate_video, book_meeting, update_lead_status, log_decision, retrieve_lead_memory, escalate_to_human."
    },
    {
      "parameters": {
        "jsCode": "const body = ($input.item.json && $input.item.json.body) || $input.item.json || {};\nconst secret = body.internal_secret || '';\nconst expected = process.env.INTERNAL_EMAIL_SECRET || '';\nif (!expected || secret !== expected) return { json: { valid: false, error: 'internal secret required', tool_name: '', tool_input: {} } };\nconst toolName = body.tool_name || '';\nconst toolInput = body.tool_input || {};\nconst valid = ['place_outbound_call','send_whatsapp','send_sms','send_email','generate_video','book_meeting','update_lead_status','log_decision','retrieve_lead_memory','escalate_to_human'];\nif (!toolName) return { json: { valid: false, error: 'tool_name required', tool_name: '', tool_input: {} } };\nif (valid.indexOf(toolName) < 0) return { json: { valid: false, error: 'unknown tool: ' + toolName + '. Available: ' + valid.join(', '), tool_name: toolName, tool_input: toolInput } };\nreturn { json: { valid: true, tool_name: toolName, tool_input: toolInput } };",
        "mode": "runOnceForEachItem"
      },
      "id": "mat-0002",
      "name": "Parse Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 500]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 },
          "conditions": [ { "id": "c1", "leftValue": "={{ $json.valid }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } } ],
          "combinator": "and"
        }
      },
      "id": "mat-0003",
      "name": "IF Valid",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 500]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "place_outbound_call", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "voice" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "send_whatsapp", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "wa" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "send_sms", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "sms" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "send_email", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "email" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "generate_video", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "video" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "book_meeting", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "book" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "update_lead_status", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "update" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "log_decision", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "decision" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "retrieve_lead_memory", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "memory" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "strict", "version": 2 }, "conditions": [ { "leftValue": "={{ $json.tool_name }}", "rightValue": "escalate_to_human", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "escalate" }
          ]
        },
        "options": {}
      },
