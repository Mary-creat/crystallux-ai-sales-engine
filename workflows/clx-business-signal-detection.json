      "parameters": {
        "jsCode": "// Build Google search query from lead data\nconst lead = $input.item.json;\n\nconst query = lead.company + ' ' + lead.city + ' hiring OR expansion OR funding OR growth OR automation 2024 2025';\n\nreturn {\n  json: {\n    id: lead.id,\n    full_name: lead.full_name,\n    company: lead.company,\n    industry: lead.industry,\n    job_title: lead.job_title,\n    city: lead.city,\n    lead_score: lead.lead_score,\n    priority_level: lead.priority_level,\n    research_summary: lead.research_summary,\n    likely_business_need: lead.likely_business_need,\n    search_query: query\n  }\n};"
      },
      "id": "clx04-0000-0000-0000-000000000006",
      "name": "Build Search Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1400, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://www.googleapis.com/customsearch/v1",
        "authentication": "genericCredentialType",
