      "id": "clx04-0000-0000-0000-000000000007",
      "name": "Google Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1640, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "3",
          "name": "Google Search"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (function() {\n  const lead = $('Build Search Query').item.json;\n  const searchData = $input.item.json;\n  \n  // Format search results into readable text\n  let resultsText = 'No search results found.';\n  if (searchData.items && searchData.items.length > 0) {\n    resultsText = searchData.items.map(function(item, i) {\n      return (i + 1) + '. ' + (item.title || '') + '\\n' + (item.snippet || '');\n    }).join('\\n\\n');\n  }\n  \n  const prompt = 'You are a business intelligence analyst for the Crystallux AI Sales Engine.\\n\\nAnalyze these search results about a company and identify the strongest business signal.\\n\\nCompany: ' + lead.company + '\\nIndustry: ' + lead.industry + '\\nCity: ' + lead.city + '\\nResearch Summary: ' + lead.research_summary + '\\n\\nSearch Results:\\n' + resultsText + '\\n\\nBased on these results identify:\\n1. What is this company currently doing or experiencing\\n2. What business signal does this represent\\n3. What type of outreach campaign would resonate most right now\\n\\nReturn ONLY raw JSON with no explanation no markdown no code blocks:\\n{\"detected_signal\": \"brief description of what the company is doing right now\", \"growth_stage\": \"Startup or Growing or Established or Declining or Pivoting\", \"recommended_campaign_type\": \"one of these exact values: automation_campaign or lead_generation_campaign or reputation_campaign or expansion_campaign or retention_campaign or general_outreach\", \"signal_confidence\": \"High or Medium or Low\", \"outreach_timing\": \"Immediate or This Week or This Month\"}';\n  \n  return JSON.stringify({\n    model: 'claude-sonnet-4-6',\n    max_tokens: 512,\n    messages: [{ role: 'user', content: prompt }]\n  });\n})() }}",
        "options": {}
      },
      "id": "clx04-0000-0000-0000-000000000008",
      "name": "Claude Analyze Signal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1880, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "2",
          "name": "Claude Anthropic"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Claude signal analysis response\nconst response = $input.item.json;\nconst lead = $('Build Search Query').item.json;\n\n// Extract text content from Claude API response\nconst rawText = response.content[0].text;\n\n// Parse the JSON — handle markdown-wrapped responses safely\nlet signal;\ntry {\n  const cleaned = rawText\n    .replace(/```json/gi, '')\n    .replace(/```/g, '')\n    .trim();\n  signal = JSON.parse(cleaned);\n} catch (e) {\n  signal = {\n    detected_signal: 'Manual review needed — AI parse error: ' + e.message,\n    growth_stage: 'Established',\n    recommended_campaign_type: 'general_outreach',\n    signal_confidence: 'Low',\n    outreach_timing: 'This Month'\n  };\n}\n\nconst now = new Date().toISOString();\n\nreturn {\n  json: {\n    id: lead.id,\n    detected_signal: signal.detected_signal || 'No signal detected',\n    growth_stage: signal.growth_stage || 'Established',\n    recommended_campaign_type: signal.recommended_campaign_type || 'general_outreach',\n    signal_confidence: signal.signal_confidence || 'Low',\n    outreach_timing: signal.outreach_timing || 'This Month',\n    lead_status: 'Signal Detected',\n    updated_at: now\n  }\n};"
      },
