    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-haiku-4-5-20251001', max_tokens: 512, messages: [{ role: 'user', content: 'You are a sales assistant for the Crystallux AI Sales Engine.\\n\\nAnalyze this reply from a prospect and determine if they are interested in learning more or booking a meeting.\\n\\nProspect: ' + $('Split In Batches').item.json.full_name + '\\nCompany: ' + $('Split In Batches').item.json.company + '\\nTheir reply: ' + ($('Split In Batches').item.json.reply_text || '').replace(/[\\n\\r]/g, ' ').replace(/\"/g, '\\\\\"') + '\\n\\nInterest signals include: yes, interested, sure, sounds good, tell me more, let\\'s talk, book a call, schedule, when are you free, how does this work, what\\'s the cost, can you show me, I\\'d like to learn more, send me details, let\\'s connect.\\n\\nNOT interested signals: no, not interested, remove me, unsubscribe, not now, maybe later, too busy, wrong person, stop emailing, please don\\'t contact me.\\n\\nReturn ONLY raw JSON no explanation no markdown:\\n{\\n  \"interest_detected\": true or false,\\n  \"confidence\": \"High\" or \"Medium\" or \"Low\",\\n  \"signal_type\": \"positive\" or \"negative\" or \"neutral\",\\n  \"recommended_action\": \"book_meeting\" or \"nurture\" or \"remove\"\\n}' }] }) }}",
        "options": {}
      },
      "id": "clx09-0000-0000-0000-000000000006",
      "name": "Claude Detect Interest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1640,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "2",
          "name": "Claude Anthropic"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// CLX Booking — Phase 9: Parse Interest Response\n// Parse Claude AI interest detection response with error handling\n\ntry {\n  const lead = $('Split In Batches').item.json;\n  const response = $('Claude Detect Interest').item.json;\n\n  // Extract text content from Claude response\n  let rawText = '';\n  if (response.content && Array.isArray(response.content)) {\n    rawText = response.content.map(c => c.text || '').join('');\n  } else if (typeof response.content === 'string') {\n    rawText = response.content;\n  }\n\n  // Clean markdown fences if present\n  rawText = rawText.replace(/```json\\s*/gi, '').replace(/```\\s*/gi, '').trim();\n\n  const parsed = JSON.parse(rawText);\n\n  return {\n    json: {\n      ...lead,\n      interest_detected: String(parsed.interest_detected === true),\n      confidence: parsed.confidence || 'Low',\n      signal_type: parsed.signal_type || 'neutral',\n      recommended_action: parsed.recommended_action || 'nurture'\n    }\n  };\n} catch (error) {\n  // On parse failure, default to not interested to avoid false positives\n  const lead = $('Split In Batches').item.json;\n  return {\n    json: {\n      ...lead,\n      interest_detected: 'false',\n      confidence: 'Low',\n      signal_type: 'neutral',\n      recommended_action: 'nurture',\n      parse_error: error.message\n    }\n  };\n}"
      },
