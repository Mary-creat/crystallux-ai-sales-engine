    {
      "parameters": {
        "jsCode": "const lead = $('Split In Batches').item.json;\n\nlet calendlyUrl = \"https://calendly.com/adesholaakintunde/free-moving-quote-toronto-gta\";\nlet clientName = \"Blonai Moving Company\";\nlet notificationEmail = \"akintundebowale@gmail.com\";\n\ntry {\n  const clientData = $('Get Client Config').first().json;\n  if (clientData && clientData.calendly_link) {\n    calendlyUrl = clientData.calendly_link;\n    clientName = clientData.client_name;\n    notificationEmail = clientData.notification_email;\n  }\n} catch(e) {\n}\n\nconst subject = \"Let's find a time — Free Moving Quote\";\n\nconst body = `Hi ${lead.full_name || 'there'},\n\nThank you for your interest in ${clientName}.\n\nWe would love to help make your move stress-free\\nand professional across Toronto GTA.\n\nClick here to book your free no-obligation quote:\\n${calendlyUrl}\n\nTakes 30 seconds to book. Confirmation sent instantly.\n\n${clientName}\\nToronto GTA`;\n\nreturn {\n  json: {\n    ...lead,\n    booking_subject: subject,\n    booking_body: body,\n    calendly_link: calendlyUrl,\n    client_name: clientName,\n    notification_email: notificationEmail,\n    booking_email_sent: true,\n    booking_email_sent_at: new Date().toISOString(),\n    lead_status: 'Booking Sent',\n    updated_at: new Date().toISOString()\n  }\n};"
      },
