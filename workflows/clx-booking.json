    {
      "parameters": {
        "jsCode": "// CLX Booking — Phase 9: Build Booking Email\n// Constructs warm personalized booking email with Calendly link\n\nconst lead = $('Split In Batches').item.json;\nconst calendlyResponse = $('Get Calendly Link').item.json;\n\n// Extract scheduling URL from Calendly response\nconst calendlyUrl = calendlyResponse.resource\n  ? calendlyResponse.resource.scheduling_url\n  : (calendlyResponse.scheduling_url || '');\n\nconst now = new Date().toISOString();\nconst firstName = (lead.full_name || '').split(' ')[0] || 'there';\n\n// Build personalized subject\nconst subject = \"Let's find a time to connect\";\n\n// Build warm email body referencing their reply\nconst body = `Hi ${firstName},\\n\\nThank you for your response — it's great to hear back from you.\\n\\nI'd love to walk you through how we can help ${lead.company || 'your team'} achieve measurable results with AI-powered outreach that works around the clock.\\n\\nHere's a quick link to grab a time that works for you:\\n${calendlyUrl}\\n\\nIt's a short 15-minute call — no pressure, just a conversation to see if there's a fit.\\n\\nLooking forward to connecting,\\nThe Crystallux Team`;\n\nreturn {\n  json: {\n    id: lead.id,\n    full_name: lead.full_name,\n    email: lead.email,\n    company: lead.company,\n    subject: subject,\n    body: body,\n    calendly_link: calendlyUrl,\n    interest_detected: true,\n    booking_email_sent: true,\n    booking_email_sent_at: now,\n    lead_status: 'Booking Sent',\n    total_emails_sent: (Number(lead.total_emails_sent) || 0) + 1,\n    last_email_sent_at: now,\n    updated_at: now\n  }\n};"
      },
