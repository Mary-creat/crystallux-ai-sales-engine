    {
      "parameters": {
        "jsCode": "// CLX Booking — Phase 9: Build Booking Email\n// With 24-hour cooldown check and unsubscribe footer\n\nconst lead = $('Split In Batches').item.json;\n\n// GUARD 7: 24-hour cooldown\nconst hoursSinceLastEmail = lead.last_email_sent_at ?\n  (Date.now() - new Date(lead.last_email_sent_at).getTime()) / 3600000 : 999;\nif (hoursSinceLastEmail < 24) return [];\nif (!lead.email || lead.email.trim() === '') return [];\nif ((Number(lead.total_emails_sent) || 0) >= 5) return [];\n\nconst BOOKING_LINK = 'https://calendly.com/adesholaakintunde/free-moving-quote-toronto-gta';\n\n// Try Calendly API response, fall back to hardcoded link\nlet calendlyUrl = BOOKING_LINK;\ntry {\n  const calendlyResponse = $('Get Calendly Link').item.json;\n  if (calendlyResponse.resource && calendlyResponse.resource.scheduling_url) {\n    calendlyUrl = calendlyResponse.resource.scheduling_url;\n  } else if (calendlyResponse.scheduling_url) {\n    calendlyUrl = calendlyResponse.scheduling_url;\n  }\n} catch (e) {\n  // Use hardcoded fallback\n}\n\nconst now = new Date().toISOString();\nconst firstName = (lead.full_name || '').split(' ')[0] || 'there';\n\nconst subject = \"Let's find a time to connect\";\n\n// HTML formatted booking email\nconst body = '<div style=\"font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#333;max-width:600px;\">'\n  + '<p style=\"margin:0 0 16px 0;\">Hi ' + firstName + ',</p>'\n  + '<p style=\"margin:0 0 16px 0;\">Thank you for your response. I would love to walk you through how we can help ' + (lead.company || 'your team') + ' achieve measurable results with AI-powered outreach that works around the clock.</p>'\n  + '<p style=\"margin:0 0 16px 0;\">Click here to book your free moving quote:<br><a href=\"' + calendlyUrl + '\" style=\"color:#2563eb;font-weight:bold;\">' + calendlyUrl + '</a></p>'\n  + '<p style=\"margin:0 0 16px 0;\">It is a short 15 minute call. No pressure, just a conversation to see if there is a fit.</p>'\n  + '<p style=\"margin:24px 0 0 0;\">Best regards,<br><strong>Mary Akintunde</strong><br><span style=\"color:#666;font-size:13px;\">Founder, Crystallux AI</span><br><span style=\"color:#666;font-size:13px;\">info@crystallux.org | crystallux.org</span></p>'\n  + '</div>'\n  + '<br><hr style=\"border:none;border-top:1px solid #e0e0e0;margin:24px 0;\"><p style=\"font-size:11px;color:#999;font-family:Arial,sans-serif;\">To unsubscribe reply STOP or <a href=\"mailto:info@crystallux.org?subject=Unsubscribe\" style=\"color:#999;\">click here</a>.<br>Sent by Crystallux AI | info@crystallux.org</p>';\n\nreturn {\n  json: {\n    id: lead.id,\n    full_name: lead.full_name,\n    email: lead.email,\n    company: lead.company,\n    subject: subject,\n    body: body,\n    calendly_link: calendlyUrl,\n    interest_detected: true,\n    booking_email_sent: true,\n    booking_email_sent_at: now,\n    lead_status: 'Booking Sent',\n    total_emails_sent: (Number(lead.total_emails_sent) || 0) + 1,\n    last_email_sent_at: now,\n    updated_at: now\n  }\n};"
      },
