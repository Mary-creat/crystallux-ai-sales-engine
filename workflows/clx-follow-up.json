    {
      "parameters": {
        "jsCode": "// CLX Follow Up — Phase 8\n// Reads lead from Split In Batches to avoid upstream node response contamination\n\nconst lead = $('Split In Batches').item.json;\n\nconst now = new Date();\nconst currentCount = typeof lead.followup_count === 'number' ? lead.followup_count : 0;\nconst newCount = currentCount + 1;\n\n// Build subject line\nconst followupSubject = 'Re: ' + (lead.email_subject || '');\n\n// Calculate next follow-up date and status based on sequence\nlet nextFollowupDate = null;\nlet newLeadStatus = 'Contacted';\n\nif (newCount === 1) {\n  // Follow-up 1 sent — schedule follow-up 2 in 5 days\n  nextFollowupDate = new Date(now.getTime() + 5 * 24 * 60 * 60 * 1000).toISOString();\n} else if (newCount === 2) {\n  // Follow-up 2 sent — schedule follow-up 3 in 10 days\n  nextFollowupDate = new Date(now.getTime() + 10 * 24 * 60 * 60 * 1000).toISOString();\n} else if (newCount >= 3) {\n  // Follow-up 3 sent — sequence complete, no reply received\n  nextFollowupDate = null;\n  newLeadStatus = 'Closed Lost';\n}\n\nreturn {\n  json: {\n    ...lead,\n    new_followup_count: newCount,\n    followup_subject: followupSubject,\n    next_followup_scheduled_at: nextFollowupDate,\n    new_lead_status: newLeadStatus,\n    followup_sent_at: now.toISOString(),\n    updated_at: now.toISOString()\n  }\n};"
      },
      "id": "clx08-0000-0000-0000-000000000006",
      "name": "Build Follow Up Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ]
    },
    {
