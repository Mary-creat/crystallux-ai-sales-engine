        "sendTo": "={{ $('Build Follow Up Email').item.json.email }}",
        "subject": "={{ $('Build Follow Up Email').item.json.followup_subject }}",
        "message": "={{ $('Build Follow Up Email').item.json.followup_message }}",
        "options": {}
      },
      "id": "clx08-0000-0000-0000-000000000007",
