        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ followup_count: $('Build Follow Up Email').item.json.new_followup_count, followup_sent_at: $('Build Follow Up Email').item.json.followup_sent_at, next_followup_scheduled_at: $('Build Follow Up Email').item.json.next_followup_scheduled_at, lead_status: $('Build Follow Up Email').item.json.new_lead_status, updated_at: $('Build Follow Up Email').item.json.updated_at }) }}",
        "options": {}
