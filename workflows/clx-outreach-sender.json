    {
      "parameters": {
        "jsCode": "// GUARD 7: Check 24-hour cooldown and all safety flags\nconst lead = $('Split In Batches').item.json;\n\n// Skip if no email\nif (!lead.email || lead.email.trim() === '') {\n  return [];\n}\n\n// Skip if do_not_contact or unsubscribed\nif (lead.do_not_contact === true || lead.unsubscribed === true) {\n  return [];\n}\n\n// Skip if sent 5+ emails\nif ((Number(lead.total_emails_sent) || 0) >= 5) {\n  return [];\n}\n\n// GUARD 7: Skip if emailed within last 24 hours\nconst hoursSinceLastEmail = lead.last_email_sent_at ?\n  (Date.now() - new Date(lead.last_email_sent_at).getTime()) / 3600000 : 999;\nif (hoursSinceLastEmail < 24) {\n  return [];\n}\n\n// GUARD 5: Append unsubscribe footer to email body\nconst unsubFooter = '\\n\\n---\\nTo unsubscribe reply STOP.';\n\nconst emailBody = (lead.email_body || '') + unsubFooter;\n\nreturn {\n  json: {\n    ...lead,\n    email_body_with_footer: emailBody\n  }\n};"
      },
      "id": "clx07-0000-0000-0000-000000000012",
      "name": "Safety Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
