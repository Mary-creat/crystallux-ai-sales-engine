    {
      "parameters": {
        "jsCode": "// CLX Outreach Sender — Calculate Follow Up and increment counters\nconst lead = $('Split In Batches').item.json;\n\nconst now = new Date();\nconst followupDate = new Date(now.getTime() + 3 * 24 * 60 * 60 * 1000);\n\nreturn {\n  json: {\n    ...lead,\n    outreach_sent_at: now.toISOString(),\n    followup_scheduled_at: followupDate.toISOString(),\n    lead_status: 'Contacted',\n    outreach_channel: 'email',\n    total_emails_sent: (Number(lead.total_emails_sent) || 0) + 1,\n    last_email_sent_at: now.toISOString(),\n    updated_at: now.toISOString()\n  }\n};"
      },
      "id": "clx07-0000-0000-0000-000000000007",
      "name": "Calculate Follow Up",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
