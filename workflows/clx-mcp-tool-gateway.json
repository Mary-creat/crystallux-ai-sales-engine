      "id": "clx12-0091",
      "name": "Fetch Pipeline Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2620,
        260
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "pTFl5SIhensUaU27",
          "name": "Supabase Crystallux"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  const allItems = $('Fetch Pipeline Health').all();\n  const leads = allItems.map(i => i.json);\n  const now = Date.now();\n  const thresholds = {\n    'New Lead': 2 * 3600000,\n    'Researched': 2 * 3600000,\n    'Scored': 2 * 3600000,\n    'Campaign Assigned': 2 * 3600000,\n    'Outreach Ready': 24 * 3600000,\n    'Contacted': 30 * 24 * 3600000\n  };\n  const counts = {};\n  const stale = [];\n  for (const lead of leads) {\n    const s = lead.lead_status || 'Unknown';\n    counts[s] = (counts[s] || 0) + 1;\n    const threshold = thresholds[s];\n    if (threshold && lead.updated_at) {\n      const age = now - new Date(lead.updated_at).getTime();\n      if (age > threshold) {\n        stale.push({ id: lead.id, full_name: lead.full_name || '', status: s, hours_stale: Math.round(age / 3600000) });\n      }\n    }\n  }\n  return {\n    json: {\n      total_leads: leads.length,\n      stage_counts: counts,\n      stale_leads: stale,\n      stale_count: stale.length,\n      health: stale.length === 0 ? 'healthy' : 'needs_attention',\n      checked_at: new Date().toISOString()\n    }\n  };\n} catch (error) {\n  return { json: { error: error.message, health: 'error' } };\n}"
      },
