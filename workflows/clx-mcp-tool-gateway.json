      "id": "clx12-0001",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        200,
        500
      ],
      "webhookId": "clx12-webhook-mcp-gateway"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const headers = $('Webhook Trigger').item.json.headers || {};\n  const apiKey = headers['x-mcp-api-key'] || headers['X-MCP-API-Key'] || '';\n\n  if (!apiKey) {\n    return { json: { valid: false, error: 'Missing X-MCP-API-Key header', tool_name: '', tool_input: {} } };\n  }\n\n  const body = $('Webhook Trigger').item.json.body || $('Webhook Trigger').item.json;\n  const toolName = body.tool_name || '';\n  const toolInput = body.tool_input || {};\n\n  const validTools = [\n    'research_lead', 'score_lead', 'get_pipeline_stats', 'scan_city',\n    'get_lead', 'list_leads', 'update_lead_status',\n    'check_system_health', 'check_pipeline_health', 'get_execution_stats'\n  ];\n\n  if (!toolName) {\n    return { json: { valid: false, error: 'Missing tool_name in request body', tool_name: '', tool_input: {} } };\n  }\n\n  if (!validTools.includes(toolName)) {\n    return { json: { valid: false, error: 'Unknown tool: ' + toolName + '. Available: ' + validTools.join(', '), tool_name: toolName, tool_input: toolInput } };\n  }\n\n  const requiredInputs = {\n    research_lead: ['lead_id'],\n    score_lead: ['lead_id'],\n    get_pipeline_stats: [],\n    scan_city: ['city', 'industry'],\n    get_lead: [],\n    list_leads: [],\n    update_lead_status: ['lead_id', 'lead_status'],\n    check_system_health: [],\n    check_pipeline_health: [],\n    get_execution_stats: []\n  };\n\n  const missing = (requiredInputs[toolName] || []).filter(f => !toolInput[f]);\n  if (missing.length > 0) {\n    return { json: { valid: false, error: 'Missing required inputs: ' + missing.join(', '), tool_name: toolName, tool_input: toolInput } };\n  }\n\n  return { json: { valid: true, tool_name: toolName, tool_input: toolInput } };\n} catch (error) {\n  return { json: { valid: false, error: error.message, tool_name: '', tool_input: {} } };\n}"
      },
