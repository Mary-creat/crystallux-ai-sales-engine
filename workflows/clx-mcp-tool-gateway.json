    {
      "parameters": {
        "jsCode": "try {\n  const allItems = $('Fetch System Health').all();\n  const leads = allItems.map(i => i.json);\n  const total = leads.length;\n  const counts = {};\n  for (const lead of leads) {\n    const s = lead.lead_status || 'Unknown';\n    counts[s] = (counts[s] || 0) + 1;\n  }\n  const active = (counts['Contacted'] || 0) + (counts['Replied'] || 0) + (counts['Booking Sent'] || 0);\n  return {\n    json: {\n      total_leads: total,\n      status_counts: counts,\n      active_conversations: active,\n      health: total > 0 ? 'operational' : 'empty',\n      checked_at: new Date().toISOString()\n    }\n  };\n} catch (error) {\n  return { json: { error: error.message, health: 'error' } };\n}"
      },
      "id": "clx12-0082",
