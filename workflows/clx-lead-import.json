        "jsonBody": "{\n  \"page\": 1,\n  \"per_page\": 25,\n  \"person_titles\": [\"Owner\", \"CEO\", \"Founder\", \"Director\"],\n  \"organization_industry_tag_ids\": [],\n  \"person_locations\": [\"Canada\"],\n  \"contact_email_status\": [\"verified\"],\n  \"prospected_by_current_team\": [\"no\"]\n}",
        "options": {}
