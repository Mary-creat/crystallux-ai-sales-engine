# Cloudflare Pages redirect rules (Netlify-format).
# Pretty URLs that rewrite to the underlying static page.

# Public quote landing — emailed link looks like crystallux.org/quote/<uuid>
/quote/*           /quote.html?id=:splat    200

# Public MGA application landings — clean URLs without .html
/join-advisor      /join-advisor.html       200
/join-carrier      /join-carrier.html       200

# Legacy aliases mentioned in earlier emails / docs.
# If insurance.crystallux.org or insurer.crystallux.org point at this
# same Pages project, /join on those hosts resolves to the right form.
/join              /join-advisor.html       200

# Cloudflare Pages serves /products/smart-quote -> /products/smart-quote.html
# natively (extensionless URL pretty-mapping is built-in). No explicit
# rewrites needed for the product pages — adding them caused a redirect
# loop with CF's own .html-stripping behavior.
