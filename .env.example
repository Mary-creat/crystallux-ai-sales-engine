# ================================================================
# Crystallux Universal AI Sales Engine
# Environment Variables Template
# ================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in every value in your .env file
# 3. NEVER commit your actual .env file to GitHub
# 4. Your .gitignore already excludes .env automatically
# ================================================================

# ── n8n Core Configuration ─────────────────────────────────────
# The public URL or IP address of your Hostinger server
N8N_HOST=your-server-ip-or-domain

# Full URL including protocol — used for webhook callbacks
WEBHOOK_URL=https://your-server-ip-or-domain

# Random 32-character string used to encrypt credentials in n8n
# Generate one at: https://randomkeygen.com
N8N_ENCRYPTION_KEY=generate-a-random-32-char-string-here

# ── Redis Authentication ──────────────────────────────────────
# Optional — see docs/setup/redis-security.md for setup steps
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=

# ── Supabase PostgreSQL Database ───────────────────────────────
# Found in Supabase dashboard under Settings → Database
POSTGRES_HOST=your-project-id.supabase.co
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-supabase-database-password

# ── Lead Discovery ─────────────────────────────────────────────
# Found in Apollo dashboard under Settings → Integrations → API
APOLLO_API_KEY=your-apollo-api-key

# ── AI Reasoning Layer ─────────────────────────────────────────
# Claude API key from console.anthropic.com
ANTHROPIC_API_KEY=your-claude-api-key

# OpenAI API key from platform.openai.com
OPENAI_API_KEY=your-openai-api-key

# ── Communication Channels ─────────────────────────────────────
# Gmail OAuth credentials from Google Cloud Console
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret

# ── Meeting Booking ────────────────────────────────────────────
# Found in Calendly dashboard under Integrations → API
CALENDLY_API_KEY=your-calendly-api-key

# ── Future SaaS Configuration ──────────────────────────────────
# Stripe keys for subscription billing — added in SaaS phase
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# JWT secret for user authentication in the frontend dashboard
JWT_SECRET=generate-a-random-64-char-string-here

# ── Notification Emails ───────────────────────────────────────
# Primary business email for outreach and unsubscribe handling
BUSINESS_EMAIL=info@crystallux.org

# Alert email for system notifications and error reports
ALERT_EMAIL=info@crystallux.org

# Owner email for admin notifications
OWNER_EMAIL=adesholaakintunde@gmail.com

# ── MCP Gateway Security ──────────────────────────────────────
# API key for authenticating MCP tool calls
# Generate: openssl rand -hex 32
# Send as header: X-MCP-API-Key: your-secret-here
MCP_WEBHOOK_SECRET=generate-a-strong-secret-here

